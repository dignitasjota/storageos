# El CLI de Prisma lee DATABASE_URL desde este archivo (o el del workspace
# que invoca el script). Apunta al Postgres del docker-compose de dev,
# expuesto en el host en el puerto 5433.
#
# Para migraciones y seed usamos el usuario admin `storageos` (bypassea RLS
# por ser owner). La app (apps/api) usa el usuario restringido
# `storageos_app`; ver apps/api/.env.example.
DATABASE_URL=postgresql://storageos:storageos@localhost:5433/storageos?schema=public

# === Seed de desarrollo ===
# Credenciales del owner del tenant demo. Se aplican al ejecutar `pnpm db:seed`
# o `pnpm db:reset`. Cambialas aqui (y en .env) si quieres usar otras.
DEMO_OWNER_EMAIL=jota@storageos.local
DEMO_OWNER_PASSWORD=Jota69
DEMO_OWNER_NAME=Jota
DEMO_TENANT_NAME=Demo Storage SL
DEMO_TENANT_SLUG=demo-storage
DEMO_TENANT_BILLING_EMAIL=billing@demo-storage.local
