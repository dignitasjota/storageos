{
  "name": "@storageos/database",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:reset": "prisma migrate reset",
    "studio": "prisma studio",
    "format": "prisma format",
    "build": "prisma generate",
    "typecheck": "prisma generate && tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "clean": "rm -rf dist .turbo node_modules/.prisma *.tsbuildinfo"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@storageos/eslint-config": "workspace:*",
    "@storageos/tsconfig": "workspace:*",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prisma": "^6.1.0",
    "typescript": "^5.7.2"
  }
}
