// ============================================================================
// FASE 5: Comunicaciones, CRM, automatizaciones, widget publico
// ============================================================================

enum LeadStatus {
  new // recien creado, sin contactar
  contacted // primer contacto realizado
  qualified // intencion real de alquiler confirmada
  won // convertido a customer + (opcional) contract/reservation
  lost // descartado

  @@map("lead_status")
}

enum LeadSource {
  widget // formulario embebible
  referral // recomendacion de cliente
  manual // alta manual por staff
  import // importado de sistema previo
  phone // llamada
  walkin // entro en el local
  other

  @@map("lead_source")
}

enum CommunicationChannel {
  email
  sms
  whatsapp

  @@map("communication_channel")
}

enum CommunicationStatus {
  pending // en outbox, todavia no encolado al provider
  processing // tomado por worker, enviando
  sent // provider confirmo aceptacion
  delivered // confirmacion de entrega (webhook provider)
  bounced // rebote permanente
  failed // fallo definitivo tras reintentos
  skipped // cancelado antes de enviar (e.g. cliente pago antes del recordatorio)

  @@map("communication_status")
}

enum CommunicationDirection {
  outbound
  inbound

  @@map("communication_direction")
}

enum MessageTemplateKind {
  system // built-in, no editable (welcome, password_reset, ...)
  transactional // editable, vinculada a evento (contract_signed, ...)
  marketing // editable, envio manual o campana

  @@map("message_template_kind")
}

enum AutomationTrigger {
  customer_created
  contract_signed
  contract_ending_soon // T-7 dias antes de end_date / cancellation notice
  contract_ended
  invoice_issued
  invoice_overdue
  invoice_paid
  reservation_confirmed
  lead_created
  review_request // envío de la solicitud de valoración (NPS)
  review_submitted // el inquilino ha enviado su valoración

  @@map("automation_trigger")
}

enum AutomationActionType {
  send_email
  send_whatsapp
  send_sms

  @@map("automation_action_type")
}

enum AutomationRunStatus {
  pending
  succeeded
  skipped // condicion no se cumplio o entidad anonimizada
  failed

  @@map("automation_run_status")
}

/// Lead: persona interesada en alquilar un trastero, todavia no customer.
/// Pipeline kanban (new -> contacted -> qualified -> won/lost).
/// Al convertirse en customer (won), se rellena `convertedCustomerId`.
model Lead {
  id                      String     @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId                String     @map("tenant_id") @db.Uuid
  status                  LeadStatus @default(new)
  source                  LeadSource @default(manual)
  firstName               String?    @map("first_name")
  lastName                String?    @map("last_name")
  companyName             String?    @map("company_name")
  email                   String?
  phone                   String?
  message                 String?
  preferredFacilityId     String?    @map("preferred_facility_id") @db.Uuid
  preferredUnitTypeId     String?    @map("preferred_unit_type_id") @db.Uuid
  preferredStartDate      DateTime?  @map("preferred_start_date") @db.Date
  estimatedDurationMonths Int?       @map("estimated_duration_months")
  budgetMonthly           Decimal?   @map("budget_monthly") @db.Decimal(10, 2)
  utmSource               String?    @map("utm_source")
  utmMedium               String?    @map("utm_medium")
  utmCampaign             String?    @map("utm_campaign")
  metadata                Json       @default("{}")
  assignedToUserId        String?    @map("assigned_to_user_id") @db.Uuid
  contactedAt             DateTime?  @map("contacted_at") @db.Timestamptz(6)
  qualifiedAt             DateTime?  @map("qualified_at") @db.Timestamptz(6)
  wonAt                   DateTime?  @map("won_at") @db.Timestamptz(6)
  lostAt                  DateTime?  @map("lost_at") @db.Timestamptz(6)
  lostReason              String?    @map("lost_reason")
  convertedCustomerId     String?    @map("converted_customer_id") @db.Uuid
  convertedContractId     String?    @map("converted_contract_id") @db.Uuid
  convertedReservationId  String?    @map("converted_reservation_id") @db.Uuid
  deletedAt               DateTime?  @map("deleted_at") @db.Timestamptz(6)
  createdAt               DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  preferredFacility    Facility?       @relation("LeadPreferredFacility", fields: [preferredFacilityId], references: [id], onDelete: SetNull)
  preferredUnitType    UnitType?       @relation("LeadPreferredUnitType", fields: [preferredUnitTypeId], references: [id], onDelete: SetNull)
  assignedTo           User?           @relation("LeadAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  convertedCustomer    Customer?       @relation("LeadConvertedCustomer", fields: [convertedCustomerId], references: [id], onDelete: SetNull)
  convertedContract    Contract?       @relation("LeadConvertedContract", fields: [convertedContractId], references: [id], onDelete: SetNull)
  convertedReservation Reservation?    @relation("LeadConvertedReservation", fields: [convertedReservationId], references: [id], onDelete: SetNull)
  communications       Communication[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, assignedToUserId])
  @@map("leads")
}

/// Plantilla de mensaje. `kind=system` para built-ins (no editables: welcome,
/// password_reset). `transactional` para automatizaciones de eventos.
/// `marketing` para campanas manuales. Variables Handlebars `{{var}}` con
/// whitelist por trigger en codigo (no en BD).
model MessageTemplate {
  id                        String               @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId                  String               @map("tenant_id") @db.Uuid
  code                      String // identificador unico por tenant (e.g. welcome_email)
  kind                      MessageTemplateKind  @default(transactional)
  channel                   CommunicationChannel @default(email)
  name                      String
  subject                   String? // email
  bodyText                  String               @map("body_text")
  bodyHtml                  String?              @map("body_html")
  locale                    String               @default("es-ES")
  isActive                  Boolean              @default(true) @map("is_active")
  /// Variables Handlebars permitidas (informativo para UI: ["customerName", "contractNumber", ...])
  variables                 String[]             @default([])
  /// Plantilla aprobada en Meta WhatsApp Business (solo channel=whatsapp).
  whatsappTemplateName      String?              @map("whatsapp_template_name")
  /// Idioma de la plantilla WABA (e.g. "es"); al enviar usa "es" si es null.
  whatsappTemplateLanguage  String?              @map("whatsapp_template_language")
  /// Nombres de variables, en orden, que mapean a los parámetros posicionales {{1}}, {{2}}... de la plantilla WABA.
  whatsappTemplateVariables String[]             @default([]) @map("whatsapp_template_variables")
  /// JSONB con metadatos: trigger asociado (informativo), tags, etc.
  metadata                  Json                 @default("{}")
  deletedAt                 DateTime?            @map("deleted_at") @db.Timestamptz(6)
  createdAt                 DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  communications  Communication[]
  automationRules AutomationRule[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("message_templates")
}

/// Comunicacion enviada (o por enviar) a un destinatario. Outbox pattern:
/// se persiste antes de pasar a la cola. Estado avanza: pending -> processing
/// -> sent -> delivered (webhook), o bounced/failed. Cancelable mientras
/// este pending (e.g. el cliente pago antes del recordatorio dunning).
model Communication {
  id                       String                 @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId                 String                 @map("tenant_id") @db.Uuid
  channel                  CommunicationChannel   @default(email)
  status                   CommunicationStatus    @default(pending)
  direction                CommunicationDirection @default(outbound)
  templateId               String?                @map("template_id") @db.Uuid
  customerId               String?                @map("customer_id") @db.Uuid
  leadId                   String?                @map("lead_id") @db.Uuid
  /// Recipient resuelto en el momento de crear la fila (snapshot).
  recipient                String
  subject                  String?
  bodyText                 String                 @map("body_text")
  bodyHtml                 String?                @map("body_html")
  /// Variables resueltas al renderizar, guardadas para auditoria.
  variables                Json                   @default("{}")
  /// Snapshot de la plantilla WABA a usar al enviar (solo whatsapp por plantilla).
  whatsappTemplateName     String?                @map("whatsapp_template_name")
  whatsappTemplateLanguage String?                @map("whatsapp_template_language")
  /// Parámetros posicionales resueltos para la plantilla WABA: { "1": "...", "2": "..." }.
  whatsappTemplateParams   Json?                  @map("whatsapp_template_params")
  /// ID del provider (Resend message_id, WhatsApp wamid, etc.) si se envio.
  providerMessageId        String?                @map("provider_message_id")
  provider                 String? // "resend", "mailpit", "whatsapp_stub"
  /// Origen del envio: nombre legible. e.g. "dunning.email_reminder", "auth.invitation".
  source                   String?
  errorMessage             String?                @map("error_message")
  retryCount               Int                    @default(0) @map("retry_count")
  scheduledFor             DateTime?              @map("scheduled_for") @db.Timestamptz(6)
  sentAt                   DateTime?              @map("sent_at") @db.Timestamptz(6)
  deliveredAt              DateTime?              @map("delivered_at") @db.Timestamptz(6)
  failedAt                 DateTime?              @map("failed_at") @db.Timestamptz(6)
  createdAt                DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  template MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  customer Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lead     Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status, scheduledFor])
  @@index([tenantId, customerId])
  @@index([tenantId, leadId])
  @@index([providerMessageId])
  @@map("communications")
}

/// Regla de automatizacion: cuando se emite el `trigger`, ejecuta `actionType`
/// con `templateId`. MVP: solo `send_email`. `conditions` reservado para Fase 6.
model AutomationRule {
  id           String               @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId     String               @map("tenant_id") @db.Uuid
  name         String
  trigger      AutomationTrigger
  actionType   AutomationActionType @map("action_type")
  templateId   String?              @map("template_id") @db.Uuid
  /// Reservado para Fase 6: condiciones extra (e.g. solo si tag X).
  conditions   Json                 @default("{}")
  /// Retraso desde el evento. 0 = inmediato. Para contract_ending_soon, define cuanto antes.
  delayMinutes Int                  @default(0) @map("delay_minutes")
  isActive     Boolean              @default(true) @map("is_active")
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  template MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  runs     AutomationRun[]

  @@index([tenantId])
  @@index([tenantId, trigger, isActive])
  @@map("automation_rules")
}

/// Log de cada vez que una regla disparo. Permite ver historico + retry
/// puntual. Cada run apunta a la communication que genero (si la creo).
model AutomationRun {
  id              String              @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId        String              @map("tenant_id") @db.Uuid
  ruleId          String              @map("rule_id") @db.Uuid
  trigger         AutomationTrigger
  status          AutomationRunStatus @default(pending)
  /// Entidad relacionada (contractId / invoiceId / customerId / leadId).
  entityType      String              @map("entity_type")
  entityId        String              @map("entity_id") @db.Uuid
  communicationId String?             @map("communication_id") @db.Uuid
  /// Snapshot del payload del evento (para retry).
  eventPayload    Json                @default("{}") @map("event_payload")
  errorMessage    String?             @map("error_message")
  startedAt       DateTime            @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt      DateTime?           @map("finished_at") @db.Timestamptz(6)

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  rule   AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, ruleId, startedAt])
  @@index([entityType, entityId])
  @@map("automation_runs")
}

// ============================================================================
// FASE 6: Operativa (tasks + incidents) + productos accesorios + reports
// ============================================================================

enum TaskType {
  cleaning
  maintenance
  inspection
  other

  @@map("task_type")
}

enum TaskStatus {
  open
  in_progress
  done
  cancelled

  @@map("task_status")
}

enum TaskPriority {
  low
  normal
  high
  urgent

  @@map("task_priority")
}

enum IncidentStatus {
  reported
  investigating
  resolved
  dismissed

  @@map("incident_status")
}

enum IncidentSeverity {
  low
  medium
  high
  critical

  @@map("incident_severity")
}

enum ProductType {
  lock
  box
  packaging
  insurance
  other

  @@map("product_type")
}

enum ProductSaleStatus {
  pending
  paid
  cancelled

  @@map("product_sale_status")
}

enum ReportStatus {
  pending
  running
  done
  failed
  expired

  @@map("report_status")
}

enum ReportFormat {
  pdf
  xlsx

  @@map("report_format")
}

/// Tarea operativa programable: limpieza, mantenimiento, inspeccion.
/// State machine: open -> in_progress -> done | cancelled (con vuelta
/// atras permitida hasta done). Asignacion a un user del tenant.
model Task {
  id                String       @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId          String       @map("tenant_id") @db.Uuid
  type              TaskType     @default(other)
  status            TaskStatus   @default(open)
  priority          TaskPriority @default(normal)
  title             String
  description       String?
  facilityId        String?      @map("facility_id") @db.Uuid
  unitId            String?      @map("unit_id") @db.Uuid
  assignedToUserId  String?      @map("assigned_to_user_id") @db.Uuid
  createdByUserId   String?      @map("created_by_user_id") @db.Uuid
  maintenancePlanId String?      @map("maintenance_plan_id") @db.Uuid
  checklist         Json         @default("[]")
  dueDate           DateTime?    @map("due_date") @db.Date
  startedAt         DateTime?    @map("started_at") @db.Timestamptz(6)
  completedAt       DateTime?    @map("completed_at") @db.Timestamptz(6)
  cancelledAt       DateTime?    @map("cancelled_at") @db.Timestamptz(6)
  cancelReason      String?      @map("cancel_reason")
  metadata          Json         @default("{}")
  deletedAt         DateTime?    @map("deleted_at") @db.Timestamptz(6)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  facility        Facility?        @relation("TaskFacility", fields: [facilityId], references: [id], onDelete: SetNull)
  unit            Unit?            @relation("TaskUnit", fields: [unitId], references: [id], onDelete: SetNull)
  assignedTo      User?            @relation("TaskAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdBy       User?            @relation("TaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  maintenancePlan MaintenancePlan? @relation(fields: [maintenancePlanId], references: [id], onDelete: SetNull)
  comments        TaskComment[]

  @@index([tenantId])
  @@index([tenantId, status, dueDate])
  @@index([tenantId, assignedToUserId])
  @@index([tenantId, facilityId])
  @@map("tasks")
}

/// Plantilla de mantenimiento recurrente: genera tareas automáticamente según
/// una frecuencia. `freq` = 'daily' | 'weekly' | 'monthly'; `weekdays` (0=dom..6=sáb)
/// solo para weekly; `dayOfMonth` (1-28) solo para monthly; `interval` = cada N.
model MaintenancePlan {
  id                String       @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId          String       @map("tenant_id") @db.Uuid
  title             String
  description       String?
  type              TaskType     @default(maintenance)
  priority          TaskPriority @default(normal)
  facilityId        String?      @map("facility_id") @db.Uuid
  assignedToUserId  String?      @map("assigned_to_user_id") @db.Uuid
  freq              String
  interval          Int          @default(1)
  weekdays          Int[]        @default([])
  dayOfMonth        Int?         @map("day_of_month")
  checklistTemplate Json         @default("[]") @map("checklist_template")
  startDate         DateTime     @map("start_date") @db.Date
  nextRunDate       DateTime     @map("next_run_date") @db.Date
  lastGeneratedAt   DateTime?    @map("last_generated_at") @db.Timestamptz(6)
  isActive          Boolean      @default(true) @map("is_active")
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  facility   Facility? @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  assignedTo User?     @relation("MaintenancePlanAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  tasks      Task[]

  @@index([tenantId])
  @@index([isActive, nextRunDate])
  @@map("maintenance_plans")
}

model TaskComment {
  id           String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  taskId       String    @map("task_id") @db.Uuid
  authorUserId String?   @map("author_user_id") @db.Uuid
  body         String
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User?  @relation("TaskCommentAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([taskId, createdAt(sort: Desc)])
  @@map("task_comments")
}

/// Incidencia reportada (problema, robo, queja, dano). Distinta de Task:
/// no se programa, se reporta. Severity gobierna escalado (high/critical
/// notifica al manager via automation rule).
model Incident {
  id                 String           @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId           String           @map("tenant_id") @db.Uuid
  status             IncidentStatus   @default(reported)
  severity           IncidentSeverity @default(medium)
  title              String
  description        String?
  facilityId         String?          @map("facility_id") @db.Uuid
  unitId             String?          @map("unit_id") @db.Uuid
  customerId         String?          @map("customer_id") @db.Uuid
  contractId         String?          @map("contract_id") @db.Uuid
  assignedToUserId   String?          @map("assigned_to_user_id") @db.Uuid
  reportedByUserId   String?          @map("reported_by_user_id") @db.Uuid
  reportedByExternal String?          @map("reported_by_external")
  occurredAt         DateTime?        @map("occurred_at") @db.Timestamptz(6)
  resolvedAt         DateTime?        @map("resolved_at") @db.Timestamptz(6)
  dismissedAt        DateTime?        @map("dismissed_at") @db.Timestamptz(6)
  resolution         String?
  metadata           Json             @default("{}")
  deletedAt          DateTime?        @map("deleted_at") @db.Timestamptz(6)
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  facility   Facility?         @relation("IncidentFacility", fields: [facilityId], references: [id], onDelete: SetNull)
  unit       Unit?             @relation("IncidentUnit", fields: [unitId], references: [id], onDelete: SetNull)
  customer   Customer?         @relation("IncidentCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  contract   Contract?         @relation("IncidentContract", fields: [contractId], references: [id], onDelete: SetNull)
  assignedTo User?             @relation("IncidentAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  reportedBy User?             @relation("IncidentReportedBy", fields: [reportedByUserId], references: [id], onDelete: SetNull)
  comments   IncidentComment[]

  @@index([tenantId])
  @@index([tenantId, status, severity])
  @@index([tenantId, facilityId])
  @@index([tenantId, customerId])
  @@map("incidents")
}

model IncidentComment {
  id           String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  incidentId   String    @map("incident_id") @db.Uuid
  authorUserId String?   @map("author_user_id") @db.Uuid
  body         String
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  author   User?    @relation("IncidentCommentAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([incidentId, createdAt(sort: Desc)])
  @@map("incident_comments")
}

/// Producto del catalogo del tenant (candado, caja, embalaje, seguro).
/// El precio es el sugerido; las ventas snapshot del precio del momento.
/// Soft delete via `deletedAt` para preservar product_sales historicos.
model Product {
  id          String      @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  sku         String
  name        String
  description String?
  type        ProductType @default(other)
  price       Decimal     @db.Decimal(10, 2)
  taxRate     Decimal     @default(21) @map("tax_rate") @db.Decimal(5, 2)
  isActive    Boolean     @default(true) @map("is_active")
  deletedAt   DateTime?   @map("deleted_at") @db.Timestamptz(6)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  stocks    ProductStock[]
  saleItems ProductSaleItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@map("products")
}

/// Stock por facility. Ajuste manual en MVP (sin movimientos). La venta
/// bloquea si quantity < line.quantity (no permitimos negativos).
model ProductStock {
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  facilityId String   @map("facility_id") @db.Uuid
  quantity   Int      @default(0)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  facility Facility @relation("ProductStockFacility", fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([productId, facilityId])
  @@index([tenantId])
  @@index([facilityId])
  @@map("product_stock")
}

/// Venta de productos accesorios. Cada venta genera (o se asocia a) una
/// invoice (Verifactu obliga). Items en product_sale_items para soportar
/// multi-linea.
model ProductSale {
  id           String            @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId     String            @map("tenant_id") @db.Uuid
  facilityId   String            @map("facility_id") @db.Uuid
  customerId   String?           @map("customer_id") @db.Uuid
  invoiceId    String?           @unique @map("invoice_id") @db.Uuid
  status       ProductSaleStatus @default(pending)
  total        Decimal           @db.Decimal(10, 2)
  notes        String?
  soldByUserId String?           @map("sold_by_user_id") @db.Uuid
  soldAt       DateTime          @default(now()) @map("sold_at") @db.Timestamptz(6)
  cancelledAt  DateTime?         @map("cancelled_at") @db.Timestamptz(6)
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  facility Facility          @relation("ProductSaleFacility", fields: [facilityId], references: [id], onDelete: Restrict)
  customer Customer?         @relation("ProductSaleCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  invoice  Invoice?          @relation("ProductSaleInvoice", fields: [invoiceId], references: [id], onDelete: SetNull)
  soldBy   User?             @relation("ProductSaleSoldBy", fields: [soldByUserId], references: [id], onDelete: SetNull)
  items    ProductSaleItem[]

  @@index([tenantId])
  @@index([tenantId, facilityId, soldAt(sort: Desc)])
  @@index([customerId])
  @@map("product_sales")
}

model ProductSaleItem {
  id           String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  saleId       String   @map("sale_id") @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  unitPrice    Decimal  @map("unit_price") @db.Decimal(10, 2)
  quantity     Int
  taxRate      Decimal  @default(21) @map("tax_rate") @db.Decimal(5, 2)
  lineSubtotal Decimal  @map("line_subtotal") @db.Decimal(10, 2)
  lineTotal    Decimal  @map("line_total") @db.Decimal(10, 2)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  sale    ProductSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product     @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([saleId])
  @@map("product_sale_items")
}

/// Ejecucion de un informe (PDF/XLSX). Encolada en BullMQ. El worker
/// genera el fichero en MinIO y rellena `downloadUrl` + `expiresAt`.
/// El usuario consulta `GET /reports/:id` para polling.
model ReportRun {
  id                String       @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId          String       @map("tenant_id") @db.Uuid
  triggeredByUserId String?      @map("triggered_by_user_id") @db.Uuid
  generatorCode     String       @map("generator_code")
  format            ReportFormat
  status            ReportStatus @default(pending)
  params            Json         @default("{}")
  downloadUrl       String?      @map("download_url")
  fileBytes         Int?         @map("file_bytes")
  errorMessage      String?      @map("error_message")
  startedAt         DateTime?    @map("started_at") @db.Timestamptz(6)
  finishedAt        DateTime?    @map("finished_at") @db.Timestamptz(6)
  expiresAt         DateTime?    @map("expires_at") @db.Timestamptz(6)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  triggeredBy User?  @relation("ReportRunTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status, createdAt(sort: Desc)])
  @@index([tenantId, generatorCode])
  @@map("report_runs")
}

// ============================================================================
// FASE 7: Control de accesos fisicos (credenciales, devices, audit log)
// ============================================================================

enum AccessMethod {
  pin
  qr
  rfid

  @@map("access_method")
}

enum AccessCredentialStatus {
  pending
  active
  suspended
  revoked
  expired

  @@map("access_credential_status")
}

enum AccessDeviceType {
  door
  unit_lock
  gate
  other

  @@map("access_device_type")
}

enum AccessResult {
  allowed
  denied_invalid_credential
  denied_inactive_credential
  denied_outside_hours
  denied_wrong_facility
  denied_dunning
  denied_unknown
  error

  @@map("access_result")
}

/// Credencial fisica/digital de un customer para acceder a sus trasteros.
/// `secretHash` guarda PIN/token-QR hashed (argon2id). `rfidUid` es el UID
/// de la tarjeta NFC y se guarda en claro (no es secreto). NO usamos
/// soft delete `deletedAt`: status='revoked' preserva el historial.
model AccessCredential {
  id                 String                 @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId           String                 @map("tenant_id") @db.Uuid
  customerId         String                 @map("customer_id") @db.Uuid
  method             AccessMethod
  status             AccessCredentialStatus @default(pending)
  label              String?
  secretHash         String?                @map("secret_hash")
  secretPreview      String?                @map("secret_preview")
  /// Copia cifrada (AES-256-GCM) del secreto pin/qr para que el inquilino
  /// pueda volver a verlo en su portal (el hash no es reversible). Null en
  /// credenciales antiguas (anteriores a esta feature) y en RFID.
  secretEncrypted    String?                @map("secret_encrypted")
  rfidUid            String?                @map("rfid_uid")
  allowedFacilityIds String[]               @default([]) @map("allowed_facility_ids")
  allowedUnitIds     String[]               @default([]) @map("allowed_unit_ids")
  allowedHours       Json                   @default("{}") @map("allowed_hours")
  /// Salta el toque de queda del local (acceso 24h, típico de staff).
  bypassCurfew       Boolean                @default(false) @map("bypass_curfew")
  /// Usos máximos (single-use = 1; pase nocturno). NULL = ilimitado.
  maxUses            Int?                   @map("max_uses")
  usesCount          Int                    @default(0) @map("uses_count")
  suspendReason      String?                @map("suspend_reason")
  expiresAt          DateTime?              @map("expires_at") @db.Timestamptz(6)
  activatedAt        DateTime?              @map("activated_at") @db.Timestamptz(6)
  suspendedAt        DateTime?              @map("suspended_at") @db.Timestamptz(6)
  revokedAt          DateTime?              @map("revoked_at") @db.Timestamptz(6)
  lastUsedAt         DateTime?              @map("last_used_at") @db.Timestamptz(6)
  contractId         String?                @map("contract_id") @db.Uuid
  metadata           Json                   @default("{}")
  createdAt          DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customer Customer    @relation("CredentialCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  contract Contract?   @relation("CredentialContract", fields: [contractId], references: [id], onDelete: SetNull)
  logs     AccessLog[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([rfidUid])
  @@map("access_credentials")
}

/// Dispositivo lector/cerradura. Cada uno tiene `apiKey` (hash) para
/// auth HTTP en `POST /access/verify`. Si va por MQTT, `mqttTopic`
/// identifica el canal donde escucha eventos.
model AccessDevice {
  id                     String           @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId               String           @map("tenant_id") @db.Uuid
  facilityId             String           @map("facility_id") @db.Uuid
  unitId                 String?          @map("unit_id") @db.Uuid
  type                   AccessDeviceType
  name                   String
  hardwareId             String           @map("hardware_id")
  apiKeyHash             String?          @map("api_key_hash")
  apiKeyPreview          String?          @map("api_key_preview")
  mqttTopic              String?          @map("mqtt_topic")
  /// Provider HTTP (LOCK_PROVIDER=http): URL del controlador a la que el
  /// servidor hace POST firmado (HMAC) para abrir, y el secreto HMAC cifrado
  /// (AES-256-GCM). Null si el device no usa el provider HTTP.
  controlUrl             String?          @map("control_url")
  controlSecretEncrypted String?          @map("control_secret_encrypted")
  isOnline               Boolean          @default(false) @map("is_online")
  lastSeenAt             DateTime?        @map("last_seen_at") @db.Timestamptz(6)
  isActive               Boolean          @default(true) @map("is_active")
  metadata               Json             @default("{}")
  createdAt              DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  facility Facility    @relation("DeviceFacility", fields: [facilityId], references: [id], onDelete: Cascade)
  unit     Unit?       @relation("DeviceUnit", fields: [unitId], references: [id], onDelete: SetNull)
  logs     AccessLog[]

  @@unique([tenantId, hardwareId])
  @@index([tenantId])
  @@index([tenantId, facilityId])
  @@index([tenantId, isOnline])
  @@map("access_devices")
}

/// Audit trail de cada intento de acceso (exitoso, denegado, error).
model AccessLog {
  id             String       @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  deviceId       String?      @map("device_id") @db.Uuid
  credentialId   String?      @map("credential_id") @db.Uuid
  customerId     String?      @map("customer_id") @db.Uuid
  method         AccessMethod
  result         AccessResult
  attemptedValue String?      @map("attempted_value")
  reason         String?
  ipAddress      String?      @map("ip_address")
  metadata       Json         @default("{}")
  occurredAt     DateTime     @default(now()) @map("occurred_at") @db.Timestamptz(6)

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  device     AccessDevice?     @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  credential AccessCredential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  customer   Customer?         @relation("AccessLogCustomer", fields: [customerId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, occurredAt(sort: Desc)])
  @@index([tenantId, customerId, occurredAt(sort: Desc)])
  @@index([tenantId, deviceId, occurredAt(sort: Desc)])
  @@index([tenantId, result])
  @@map("access_logs")
}

// ============================================================================
// FASE 8: Super admin + support tickets
// ============================================================================

enum SuperAdminRole {
  superadmin
  support

  @@map("super_admin_role")
}

enum SupportTicketStatus {
  open
  in_progress
  waiting_user
  resolved
  closed

  @@map("support_ticket_status")
}

enum SupportTicketPriority {
  low
  normal
  high
  urgent

  @@map("support_ticket_priority")
}

/// Super administradores de la plataforma. Sin `tenantId`: trabajan a
/// nivel global. Su autenticacion es independiente de la de tenant users
/// (JWT con purpose='superadmin', SUPER_ADMIN_JWT_SECRET).
model SuperAdmin {
  id                              String         @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  email                           String         @unique
  passwordHash                    String         @map("password_hash")
  fullName                        String         @map("full_name")
  role                            SuperAdminRole @default(support)
  isActive                        Boolean        @default(true) @map("is_active")
  twoFactorSecretEncrypted        String?        @map("two_factor_secret")
  twoFactorPendingSecretEncrypted String?        @map("two_factor_pending_secret")
  twoFactorEnabled                Boolean        @default(false) @map("two_factor_enabled")
  twoFactorEnrolledAt             DateTime?      @map("two_factor_enrolled_at") @db.Timestamptz(6)
  lastLoginAt                     DateTime?      @map("last_login_at") @db.Timestamptz(6)
  createdAt                       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  ticketsAssigned    SupportTicket[]          @relation("TicketAssignedAdmin")
  messagesAuthored   SupportTicketMessage[]   @relation("MessageAuthorAdmin")
  impersonationLogs  ImpersonationLog[]       @relation("ImpersonationAdmin")
  recoveryCodes      SuperAdminRecoveryCode[]
  refreshSessions    SuperAdminSession[]
  auditLogs          SuperAdminAuditLog[]
  tenantInteractions TenantInteraction[]      @relation("TenantInteractionAuthor")
  tenantFollowups    TenantFollowup[]         @relation("TenantFollowupAuthor")

  @@map("super_admins")
}

/// Codigos de recuperacion 2FA para super admin. 10 codigos `XXXX-XXXX`
/// hashed argon2id, single-use.
model SuperAdminRecoveryCode {
  id           String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  superAdminId String    @map("super_admin_id") @db.Uuid
  codeHash     String    @map("code_hash")
  usedAt       DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  superAdmin SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)

  @@index([superAdminId])
  @@map("super_admin_recovery_codes")
}

/// Sesion de refresh del super admin (cookie httpOnly). Mismo patron
/// que User.Session: token opaco `<sessionId>.<secret>`, hash argon2id.
/// Detecta reuso (paranoid).
model SuperAdminSession {
  id                  String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  superAdminId        String    @map("super_admin_id") @db.Uuid
  refreshTokenHash    String    @map("refresh_token_hash")
  userAgent           String?   @map("user_agent")
  ipAddress           String?   @map("ip_address")
  expiresAt           DateTime  @map("expires_at") @db.Timestamptz(6)
  rotatedAt           DateTime? @map("rotated_at") @db.Timestamptz(6)
  revokedAt           DateTime? @map("revoked_at") @db.Timestamptz(6)
  revokedReason       String?   @map("revoked_reason")
  replacedBySessionId String?   @map("replaced_by_session_id") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  superAdmin SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)

  @@index([superAdminId])
  @@index([expiresAt])
  @@map("super_admin_sessions")
}

/// Ticket de soporte de un tenant a la plataforma. RLS especial: el tenant
/// solo ve sus propios tickets; los super admins ven todos via cliente
/// admin que bypassa RLS.
model SupportTicket {
  id              String                @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId        String                @map("tenant_id") @db.Uuid
  createdByUserId String?               @map("created_by_user_id") @db.Uuid
  assignedAdminId String?               @map("assigned_admin_id") @db.Uuid
  subject         String
  status          SupportTicketStatus   @default(open)
  priority        SupportTicketPriority @default(normal)
  category        String?
  closedAt        DateTime?             @map("closed_at") @db.Timestamptz(6)
  resolvedAt      DateTime?             @map("resolved_at") @db.Timestamptz(6)
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdBy     User?                  @relation("TicketCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  assignedAdmin SuperAdmin?            @relation("TicketAssignedAdmin", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  messages      SupportTicketMessage[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([assignedAdminId])
  @@map("support_tickets")
}

/// Mensaje en un ticket. `authorUserId` o `authorAdminId`, no ambos.
/// `isInternal=true` solo visible para super admins (notas internas).
model SupportTicketMessage {
  id            String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  ticketId      String   @map("ticket_id") @db.Uuid
  authorUserId  String?  @map("author_user_id") @db.Uuid
  authorAdminId String?  @map("author_admin_id") @db.Uuid
  body          String
  isInternal    Boolean  @default(false) @map("is_internal")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorUser  User?         @relation("MessageAuthorUser", fields: [authorUserId], references: [id], onDelete: SetNull)
  authorAdmin SuperAdmin?   @relation("MessageAuthorAdmin", fields: [authorAdminId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@map("support_ticket_messages")
}

/// Log de impersonaciones de super admin a tenant. Tabla global (sin RLS)
/// para que solo super admins lean. Audita "quien entro a que tenant cuando".
model ImpersonationLog {
  id           String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  superAdminId String    @map("super_admin_id") @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  reason       String
  ipAddress    String?   @map("ip_address")
  userAgent    String?   @map("user_agent")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  superAdmin SuperAdmin @relation("ImpersonationAdmin", fields: [superAdminId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([superAdminId, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("impersonation_logs")
}

/// Certificado digital PKCS#12 del tenant para autenticar a la AEAT en
/// Veri*Factu (RD 1007/2023). Cada tenant sube su propio certificado FNMT
/// (o Camerfirma/ANCERT). El SaaS lo cifra con `MASTER_ENCRYPTION_KEY`
/// (AES-256-GCM via CryptoService) y lo usa para mTLS al endpoint AEAT.
///
/// Histórico de credenciales AEAT del tenant (Fase 11A.2). Se guardan
/// todas las rotaciones: al subir un cert nuevo se revoca el activo
/// (`revoked_at`/`revoked_reason='replaced_by_new_upload'`) y se inserta
/// una fila nueva. La "credencial activa" siempre se filtra por
/// `revoked_at IS NULL` (a nivel aplicación, ordenada por uploaded_at
/// desc como red de seguridad ante eventuales duplicados).
model TenantAeatCredential {
  id                    String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId              String    @map("tenant_id") @db.Uuid
  certP12Encrypted      Bytes     @map("cert_p12_encrypted")
  certPasswordEncrypted String    @map("cert_password_encrypted")
  certCommonName        String    @map("cert_common_name")
  certNif               String    @map("cert_nif")
  certIssuer            String    @map("cert_issuer")
  certValidFrom         DateTime  @map("cert_valid_from") @db.Timestamptz(6)
  certValidTo           DateTime  @map("cert_valid_to") @db.Timestamptz(6)
  environment           String    @default("sandbox")
  uploadedById          String    @map("uploaded_by_id") @db.Uuid
  uploadedAt            DateTime  @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  revokedAt             DateTime? @map("revoked_at") @db.Timestamptz(6)
  revokedReason         String?   @map("revoked_reason")

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation("AeatCredentialUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([tenantId, revokedAt], map: "tenant_aeat_credentials_tenant_id_active_idx")
  @@map("tenant_aeat_credentials")
}

/// Integración contable con Holded por tenant (API key cifrada AES-GCM).
model HoldedSettings {
  id              String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId        String    @unique @map("tenant_id") @db.Uuid
  apiKeyEncrypted String    @map("api_key_encrypted")
  enabled         Boolean   @default(false)
  lastSyncAt      DateTime? @map("last_sync_at") @db.Timestamptz(6)
  lastError       String?   @map("last_error")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("holded_settings")
}

/// Notificación in-app del panel (feed de actividad del tenant). Bandeja
/// compartida por el equipo: `readAt` marca leída para todo el tenant.
model Notification {
  id        String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  /// e.g. "lead.created", "invoice.overdue", "incident.created", "invoice.paid"
  type      String
  title     String
  body      String?
  /// Ruta del panel a la que lleva (e.g. "/leads", "/invoices/<id>").
  link      String?
  readAt    DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, readAt])
  @@index([tenantId, createdAt])
  @@map("notifications")
}

/// Valoracion (NPS) del inquilino. Se solicita por enlace publico con token
/// (manual o por cron) y se rellena en la pagina publica `/review/[token]`.
model Review {
  id             String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  customerId     String    @map("customer_id") @db.Uuid
  contractId     String?   @map("contract_id") @db.Uuid
  /// Token opaco para el enlace publico de valoracion.
  token          String    @unique
  tokenExpiresAt DateTime  @map("token_expires_at") @db.Timestamptz(6)
  /// pending | submitted | expired
  status         String    @default("pending")
  /// Net Promoter Score 0-10 (null hasta que se rellena).
  npsScore       Int?      @map("nps_score")
  /// Valoracion 1-5 estrellas opcional.
  rating         Int?
  comment        String?
  /// email | whatsapp | manual
  channel        String?
  source         String?
  requestedAt    DateTime  @default(now()) @map("requested_at") @db.Timestamptz(6)
  submittedAt    DateTime? @map("submitted_at") @db.Timestamptz(6)
  ip             String?
  userAgent      String?   @map("user_agent")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contract Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([contractId])
  @@map("reviews")
}

/// Configuración Redsys (TPV bancario) por tenant. Clave secreta cifrada.
/// Config de GoCardless por tenant (domiciliación SEPA gestionada). El access
/// token y el webhook secret se cifran AES-256-GCM (como Redsys/Holded).
model GoCardlessSettings {
  id                     String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId               String   @unique @map("tenant_id") @db.Uuid
  accessTokenEncrypted   String   @map("access_token_encrypted")
  webhookSecretEncrypted String   @map("webhook_secret_encrypted")
  /// "sandbox" | "live".
  environment            String   @default("sandbox")
  enabled                Boolean  @default(false)
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("gocardless_settings")
}

model RedsysSettings {
  id                 String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId           String   @unique @map("tenant_id") @db.Uuid
  merchantCode       String   @map("merchant_code")
  terminal           String   @default("1")
  secretKeyEncrypted String   @map("secret_key_encrypted")
  /// "test" (sis-t) | "live" (sis).
  environment        String   @default("test")
  enabled            Boolean  @default(false)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("redsys_settings")
}

/// Pedido Redsys: mapea el `Ds_Merchant_Order` (12 chars) a una factura para
/// poder resolver la notificación servidor-a-servidor del banco.
model RedsysOrder {
  order       String    @id
  tenantId    String    @map("tenant_id") @db.Uuid
  invoiceId   String    @map("invoice_id") @db.Uuid
  amountCents Int       @map("amount_cents")
  /// "pending" | "paid" | "failed"
  status      String    @default("pending")
  dsResponse  String?   @map("ds_response")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  paidAt      DateTime? @map("paid_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([invoiceId])
  @@map("redsys_orders")
}

// ============================================================================
// Fase 11A.1: eventos de seguridad globales (sin tenant_id, sin RLS).
// ============================================================================

/// Eventos de seguridad globales sin contexto de tenant: intentos de login
/// contra slugs o emails inexistentes, throttles disparados, reuso de
/// refresh tokens, etc. No se pueden guardar en `audit_logs` porque esa
/// tabla requiere `tenant_id NOT NULL`.
///
/// Tabla global (sin RLS): solo accesible via `PrismaAdminService`. Visible
/// unicamente para super admins. Retencion 90 dias gestionada por cron.
enum SecurityEventType {
  login_failed_email_not_found
  login_failed_tenant_not_found
  login_failed_wrong_password
  login_failed_throttled
  register_throttled
  password_reset_throttled
  invitation_token_invalid
  refresh_token_reuse

  @@map("security_event_type")
}

model SecurityEvent {
  id                  String            @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  occurredAt          DateTime          @default(now()) @map("occurred_at") @db.Timestamptz(6)
  eventType           SecurityEventType @map("event_type")
  emailAttempted      String?           @map("email_attempted")
  tenantSlugAttempted String?           @map("tenant_slug_attempted")
  ipAddress           String?           @map("ip_address") @db.Inet
  userAgent           String?           @map("user_agent")
  reason              String?
  rawMetadata         Json?             @map("raw_metadata")

  @@index([occurredAt(sort: Desc)])
  @@index([eventType, occurredAt(sort: Desc)])
  @@index([emailAttempted, occurredAt(sort: Desc)])
  @@map("security_events")
}

// ============================================================================
// Fase 12A.3: audit logs del super admin (sin tenant_id, sin RLS).
// ============================================================================

/// Audit logs de acciones globales de super admin (login, 2FA, impersonation,
/// suspend/reactivate de tenants, etc.). Distinto de `audit_logs` porque esa
/// tabla requiere `tenant_id NOT NULL` y el super admin opera fuera de un
/// tenant especifico. Distinto de `security_events` porque aqui registramos
/// ACCIONES exitosas y autorizadas del propio super admin, no intentos
/// fallidos / anomalias.
///
/// Tabla global (sin RLS): solo accesible via `PrismaAdminService`. Visible
/// unicamente para super admins via `/admin/audit-logs`. La columna
/// `targetTenantId` permite filtrar acciones que afectan a un tenant
/// concreto (por ejemplo `admin.tenant.impersonate`).
model SuperAdminAuditLog {
  id             String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  occurredAt     DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)
  superAdminId   String?  @map("super_admin_id") @db.Uuid
  action         String
  targetType     String?  @map("target_type")
  targetId       String?  @map("target_id") @db.Uuid
  targetTenantId String?  @map("target_tenant_id") @db.Uuid
  changes        Json?
  ipAddress      String?  @map("ip_address") @db.Inet
  userAgent      String?  @map("user_agent")

  superAdmin SuperAdmin? @relation(fields: [superAdminId], references: [id], onDelete: SetNull)

  @@index([occurredAt(sort: Desc)])
  @@index([superAdminId, occurredAt(sort: Desc)])
  @@index([targetTenantId, occurredAt(sort: Desc)])
  @@index([action, occurredAt(sort: Desc)])
  @@map("super_admin_audit_logs")
}

// ============================================================================
// Dedup de webhooks Stripe entrantes (sin tenant_id, sin RLS).
// ============================================================================

/// Registro de eventos Stripe ya procesados. Stripe garantiza entrega
/// at-least-once: reintentos y duplicados (incluso concurrentes) son
/// normales. El `StripeWebhookController` inserta el `event.id` ANTES de
/// procesar; un duplicado choca con la PK y se descarta. Si el handler
/// falla, la fila se borra para que el retry de Stripe vuelva a entrar.
///
/// Tabla global (sin RLS): el webhook llega antes de resolver tenant
/// context; solo se accede via `PrismaAdminService`. Limpieza a 30 dias
/// (cron diario) — Stripe deja de reintentar mucho antes.
model ProcessedStripeEvent {
  /// `event.id` de Stripe (`evt_...`).
  id         String   @id
  eventType  String   @map("event_type")
  receivedAt DateTime @default(now()) @map("received_at") @db.Timestamptz(6)

  @@index([receivedAt])
  @@map("processed_stripe_events")
}

/// Dedup de eventos entrantes de GoCardless (reentrega lotes / desordenado).
model ProcessedGoCardlessEvent {
  /// `event.id` de GoCardless (`EV...`).
  id         String   @id
  eventType  String   @map("event_type")
  receivedAt DateTime @default(now()) @map("received_at") @db.Timestamptz(6)

  @@index([receivedAt])
  @@map("processed_gocardless_events")
}

// ============================================================================
// Fase 14A.3: API keys + webhooks salientes.
// ============================================================================

/// Tokens de larga duracion para integraciones programaticas. Alternativa
/// al JWT de usuario. Formato `sk_live_<tenantId>.<secret>`. El plaintext
/// se devuelve UNA SOLA VEZ al crear o rotar; en BD vive el hash argon2id
/// del secret. `keyPrefix` ("sk_live_<tenantId>") se guarda en claro solo
/// para mostrarlo en la UI.
///
/// `scopes` es informativo en MVP (todos los tokens tienen acceso completo
/// a los endpoints que aceptan API key). Se enforcing por permission set
/// en un sub-bloque posterior.
model ApiKey {
  id              String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  name            String
  keyPrefix       String    @map("key_prefix")
  keyHash         String    @map("key_hash")
  scopes          String[]
  lastUsedAt      DateTime? @map("last_used_at") @db.Timestamptz(6)
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdByUserId String    @map("created_by_user_id") @db.Uuid

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation("ApiKeyCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, revokedAt])
  @@map("api_keys")
}

/// Webhook saliente registrado por un tenant. Cuando ocurre un evento de
/// dominio incluido en `events`, el SaaS hace POST a `url` con payload
/// firmado HMAC SHA-256. El `secret` viaja cifrado AES-256-GCM
/// (CryptoService) y se devuelve al usuario UNA SOLA VEZ al crear/rotar.
model Webhook {
  id        String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String
  url       String
  secret    String
  events    String[]
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([tenantId, isActive])
  @@map("webhooks")
}

/// Cada intento de entrega de un evento a un webhook. Sirve como audit
/// trail y permite reintento manual desde la UI. Retry exponencial via
/// BullMQ (60s, 5min, 30min). Tras `attempts >= 3`, el delivery se marca
/// como `failed` y no se reintenta automaticamente.
model WebhookDelivery {
  id           String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  webhookId    String    @map("webhook_id") @db.Uuid
  eventType    String    @map("event_type")
  payload      Json
  signature    String
  attempts     Int       @default(0)
  status       String    @default("pending")
  statusCode   Int?      @map("status_code")
  responseBody String?   @map("response_body")
  errorMessage String?   @map("error_message")
  scheduledFor DateTime  @map("scheduled_for") @db.Timestamptz(6)
  deliveredAt  DateTime? @map("delivered_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([webhookId, createdAt(sort: Desc)])
  @@map("webhook_deliveries")
}

/// Interaccion manual con un inquilino (llamada, visita, nota de lo hablado).
/// Complementa el outbox `communications` (envios salientes) para el historico
/// completo de comunicaciones con el cliente.
model CustomerInteraction {
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  type       String   @default("note")
  content    String
  occurredAt DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User?    @relation("CustomerInteractionAuthor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, customerId])
  @@map("customer_interactions")
}

/// Chat bidireccional entre el inquilino (portal) y el staff. Un hilo por
/// cliente; `senderType` distingue quién escribió.
model CustomerMessage {
  id           String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  customerId   String    @map("customer_id") @db.Uuid
  /// "customer" | "staff".
  senderType   String    @map("sender_type")
  /// Canal de origen: "portal" | "whatsapp" | "email".
  channel      String    @default("portal")
  /// Usuario del staff que escribió (null si lo escribió el inquilino).
  senderUserId String?   @map("sender_user_id") @db.Uuid
  body         String
  /// Cuándo lo leyó el destinatario (null = no leído).
  readAt       DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sender   User?    @relation("CustomerMessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, customerId, createdAt])
  @@map("customer_messages")
}

/// Pregunta frecuente del centro de ayuda: el staff las define y el inquilino
/// las consulta en su portal.
model FaqEntry {
  id          String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  question    String
  answer      String
  /// Orden de aparición (asc).
  position    Int      @default(0)
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("faq_entries")
}

/// Pago de la suscripcion SaaS del tenant (lo que la empresa paga por la
/// plataforma). Desacoplado del gateway: `provider` distingue el origen
/// (stripe/manual/...). Lo llena el webhook de Stripe + un sync idempotente.
model TenantSubscriptionPayment {
  id             String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  provider       String    @default("stripe")
  externalId     String?   @map("external_id")
  status         String    @default("paid")
  amount         Decimal   @db.Decimal(12, 2)
  discount       Decimal?  @db.Decimal(12, 2)
  currency       String    @default("EUR") @db.Char(3)
  planSlug       String?   @map("plan_slug")
  planName       String?   @map("plan_name")
  description    String?
  periodStart    DateTime? @map("period_start") @db.Timestamptz(6)
  periodEnd      DateTime? @map("period_end") @db.Timestamptz(6)
  paidAt         DateTime? @map("paid_at") @db.Timestamptz(6)
  invoiceUrl     String?   @map("invoice_url")
  pdfUrl         String?   @map("pdf_url")
  // Rastreo de reintentos de cobro (retry analysis).
  failedAttempts Int       @default(0) @map("failed_attempts")
  firstFailedAt  DateTime? @map("first_failed_at") @db.Timestamptz(6)
  recoveredAt    DateTime? @map("recovered_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice PlatformInvoice?

  @@index([tenantId, paidAt])
  @@index([firstFailedAt])
  @@map("tenant_subscription_payments")
}

/// Cupones de descuento de PLATAFORMA (StorageOS -> tenant), aplicables al
/// cobro manual de la suscripción SaaS. Tabla global sin RLS (solo super admin).
/// Distinta de `PromoCode` (esos son del negocio del TENANT a sus inquilinos).
model PlatformCoupon {
  id            String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  code          String    @unique
  discountType  String    @map("discount_type")
  discountValue Decimal   @map("discount_value") @db.Decimal(12, 2)
  validUntil    DateTime? @map("valid_until") @db.Timestamptz(6)
  maxUses       Int?      @map("max_uses")
  usedCount     Int       @default(0) @map("used_count")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("platform_coupons")
}

/// Datos fiscales del emisor (StorageOS) para las facturas de suscripción.
/// Singleton (una sola fila). Tabla global sin RLS (solo super admin).
model PlatformBillingSettings {
  id           String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  legalName    String   @default("") @map("legal_name")
  taxId        String   @default("") @map("tax_id")
  address      String?
  city         String?
  postalCode   String?  @map("postal_code")
  country      String   @default("ES")
  email        String?
  taxRate      Decimal  @default(21) @map("tax_rate") @db.Decimal(5, 2)
  seriesPrefix String   @default("SAAS") @map("series_prefix")
  enabled      Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("platform_billing_settings")
}

/// Factura de suscripción emitida por StorageOS a un tenant. Tabla global
/// (solo super admin la gestiona). Numeración secuencial por serie (año).
model PlatformInvoice {
  id            String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  series        String
  number        Int
  fullNumber    String    @map("full_number")
  tenantId      String    @map("tenant_id") @db.Uuid
  tenantName    String    @map("tenant_name")
  tenantTaxId   String?   @map("tenant_tax_id")
  tenantEmail   String?   @map("tenant_email")
  tenantAddress String?   @map("tenant_address")
  planSlug      String?   @map("plan_slug")
  planName      String?   @map("plan_name")
  concept       String?
  periodStart   DateTime? @map("period_start") @db.Timestamptz(6)
  periodEnd     DateTime? @map("period_end") @db.Timestamptz(6)
  baseAmount    Decimal   @map("base_amount") @db.Decimal(12, 2)
  taxRate       Decimal   @map("tax_rate") @db.Decimal(5, 2)
  taxAmount     Decimal   @map("tax_amount") @db.Decimal(12, 2)
  total         Decimal   @db.Decimal(12, 2)
  currency      String    @default("EUR")
  status        String    @default("issued")
  issuedAt      DateTime  @default(now()) @map("issued_at") @db.Timestamptz(6)
  pdfUrl        String?   @map("pdf_url")
  paymentId     String?   @unique @map("payment_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant  Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payment TenantSubscriptionPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([series, number])
  @@index([tenantId, issuedAt(sort: Desc)])
  @@map("platform_invoices")
}

/// Interaccion/conversacion del super admin con un tenant (llamada, email,
/// reunion, nota de lo hablado). Replica el patron de `customer_interactions`
/// del panel del tenant pero a nivel plataforma: el autor es un super admin.
/// Solo lo consume el panel admin via PrismaAdminService (bypassa RLS); la
/// policy RLS queda por coherencia/defensa.
model TenantInteraction {
  id           String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  superAdminId String?  @map("super_admin_id") @db.Uuid
  type         String   @default("note")
  content      String
  link         String?
  occurredAt   DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  superAdmin SuperAdmin? @relation("TenantInteractionAuthor", fields: [superAdminId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, occurredAt])
  @@map("tenant_interactions")
}

/// Config (singleton) de las alertas proactivas de plataforma: el super admin
/// recibe un digest por email de tenants en past_due o trials por expirar.
model PlatformAlertSettings {
  id                  String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  enabled             Boolean  @default(false)
  alertEmail          String?  @map("alert_email")
  notifyPastDue       Boolean  @default(true) @map("notify_past_due")
  notifyTrialExpiring Boolean  @default(true) @map("notify_trial_expiring")
  trialExpiringDays   Int      @default(3) @map("trial_expiring_days")
  /// Emails automáticos de ciclo de vida al OWNER del tenant (bienvenida, trial
  /// por expirar, pago fallido). Config aquí para reusar el mismo singleton.
  lifecycleEnabled    Boolean  @default(false) @map("lifecycle_enabled")
  sendWelcome         Boolean  @default(true) @map("send_welcome")
  sendTrialReminders  Boolean  @default(true) @map("send_trial_reminders")
  sendPastDue         Boolean  @default(true) @map("send_past_due")
  /// Resumen semanal de KPIs (MRR/churn/altas) por email al super admin (lunes 08:00).
  weeklyDigestEnabled Boolean  @default(false) @map("weekly_digest_enabled")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("platform_alert_settings")
}

/// Registro de idempotencia de los emails de ciclo de vida enviados al tenant:
/// cada `type` (welcome | trial_t7 | trial_t3 | trial_t1 | past_due) se manda
/// una sola vez por tenant (UNIQUE tenant+type). Tabla global, sin RLS.
model TenantLifecycleEmail {
  id       String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId String   @map("tenant_id") @db.Uuid
  type     String
  sentAt   DateTime @default(now()) @map("sent_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type])
  @@index([tenantId])
  @@map("tenant_lifecycle_emails")
}

/// Override de feature premium por tenant (el super admin activa/desactiva una
/// feature concreta sin cambiar el plan). `enabled=true` la añade, `false` la quita.
model TenantFeatureOverride {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  feature   String
  enabled   Boolean  @default(true)
  source    String   @default("manual")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, feature])
  @@map("tenant_feature_overrides")
}

/// Seguimiento/recordatorio del staff sobre un inquilino (CRM): fecha + estado.
model CustomerFollowup {
  id          String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  customerId  String    @map("customer_id") @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  title       String
  note        String?
  dueDate     DateTime  @map("due_date") @db.Date
  /// "pending" | "done".
  status      String    @default("pending")
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User?    @relation("CustomerFollowupAuthor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status, dueDate])
  @@index([customerId])
  @@map("customer_followups")
}

/// Cierre de caja diario (arqueo de efectivo): cuadra el efectivo contado con lo
/// registrado (pagos `cash` del día). Uno por día y tenant.
model CashClosure {
  id             String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  /// NULL = caja global del tenant; con valor = arqueo de un local concreto.
  facilityId     String?  @map("facility_id") @db.Uuid
  closureDate    DateTime @map("closure_date") @db.Date
  expectedCash   Decimal  @default(0) @map("expected_cash") @db.Decimal(10, 2)
  countedCash    Decimal  @default(0) @map("counted_cash") @db.Decimal(10, 2)
  difference     Decimal  @default(0) @db.Decimal(10, 2)
  notes          String?
  closedByUserId String?  @map("closed_by_user_id") @db.Uuid
  closedAt       DateTime @default(now()) @map("closed_at") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  facility Facility? @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  closedBy User?     @relation("CashClosureAuthor", fields: [closedByUserId], references: [id], onDelete: SetNull)

  // Unicidad real (cierre único global/por-local por día) via índices parciales
  // en SQL (migración 20260708150000): Prisma no representa índices parciales.
  @@index([tenantId, closureDate])
  @@map("cash_closures")
}

/// Seguimiento/recordatorio del super admin sobre un tenant ("llamar el día X",
/// "el trial vence, contactar"): tarea con fecha de recordatorio + estado.
model TenantFollowup {
  id           String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  superAdminId String?   @map("super_admin_id") @db.Uuid
  title        String
  note         String?
  dueDate      DateTime  @map("due_date") @db.Date
  /// "pending" | "done".
  status       String    @default("pending")
  completedAt  DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  superAdmin SuperAdmin? @relation("TenantFollowupAuthor", fields: [superAdminId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status, dueDate])
  @@map("tenant_followups")
}

/// Config del dunning del SaaS (cobro de tenants morosos). Singleton.
model PlatformDunningSettings {
  id            String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  enabled       Boolean  @default(false)
  reminder1Days Int      @default(3) @map("reminder1_days")
  reminder2Days Int      @default(10) @map("reminder2_days")
  suspendDays   Int      @default(21) @map("suspend_days")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("platform_dunning_settings")
}

/// Acción de dunning ejecutada sobre un tenant, para idempotencia. La clave
/// única (tenant, step, period_end) evita repetir el mismo paso en un ciclo de
/// impago; al pagar cambia el period_end → nuevo ciclo.
model PlatformDunningEvent {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  step      String
  periodEnd DateTime @map("period_end") @db.Timestamptz(6)
  sentAt    DateTime @default(now()) @map("sent_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, step, periodEnd])
  @@index([tenantId])
  @@map("platform_dunning_events")
}

/// Feed de notificaciones del super admin (eventos de plataforma). Global.
model SuperAdminNotification {
  id        String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  type      String
  title     String
  body      String?
  link      String?
  readAt    DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)])
  @@map("super_admin_notifications")
}

/// Banner global mostrado a todos los tenants en su panel. Singleton.
model PlatformBanner {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  message   String   @default("")
  level     String   @default("info")
  enabled   Boolean  @default(false)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("platform_banner")
}

/// Documentos legales de la plataforma (términos, privacidad), editables por el
/// super admin. Global (sin tenant): son las condiciones del prestador del SaaS.
model PlatformLegalDocument {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug      String   @unique
  title     String
  content   String   @default("")
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("platform_legal_documents")
}

/// Dedupe de ejecuciones de crons entre réplicas: cada cron reclama su
/// ejecución diaria insertando (name, run_on); la PK garantiza un solo ganador.
/// Global (sin tenant, sin RLS).
model CronRun {
  name      String
  runOn     DateTime @map("run_on") @db.Date
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([name, runOn])
  @@map("cron_runs")
}

/// Máquina de estados del expediente de impago (overlock → requerimiento →
/// disposición). El software orquesta; nunca dispone solo.
enum DelinquencyCaseStatus {
  open
  overlocked
  final_notice
  resolution_pending
  disposal
  closed_paid
  closed_disposed
  closed_cancelled

  @@map("delinquency_case_status")
}

/// Expediente de impago de un contrato. La deuda viva se recalcula de las
/// facturas; `debtSnapshot` es la foto (céntimos) al abrir.
model DelinquencyCase {
  id                  String                @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId            String                @map("tenant_id") @db.Uuid
  contractId          String                @map("contract_id") @db.Uuid
  customerId          String                @map("customer_id") @db.Uuid
  unitId              String?               @map("unit_id") @db.Uuid
  facilityId          String?               @map("facility_id") @db.Uuid
  status              DelinquencyCaseStatus @default(open)
  debtSnapshot        Int                   @default(0) @map("debt_snapshot")
  disposalType        String?               @map("disposal_type")
  openedAt            DateTime              @default(now()) @map("opened_at") @db.Timestamptz(6)
  overlockedAt        DateTime?             @map("overlocked_at") @db.Timestamptz(6)
  finalNoticeAt       DateTime?             @map("final_notice_at") @db.Timestamptz(6)
  finalNoticeDeadline DateTime?             @map("final_notice_deadline") @db.Timestamptz(6)
  resolutionPendingAt DateTime?             @map("resolution_pending_at") @db.Timestamptz(6)
  disposedAt          DateTime?             @map("disposed_at") @db.Timestamptz(6)
  closedAt            DateTime?             @map("closed_at") @db.Timestamptz(6)
  openedByUserId      String?               @map("opened_by_user_id") @db.Uuid
  notes               String?
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contract Contract               @relation(fields: [contractId], references: [id], onDelete: Cascade)
  customer Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  unit     Unit?                  @relation(fields: [unitId], references: [id], onDelete: SetNull)
  openedBy User?                  @relation("DelinquencyCaseOpenedBy", fields: [openedByUserId], references: [id], onDelete: SetNull)
  events   DelinquencyCaseEvent[]
  files    DelinquencyCaseFile[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([contractId])
  @@map("delinquency_cases")
}

/// Timeline inmutable del expediente (patrón contract_events).
model DelinquencyCaseEvent {
  id              String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  caseId          String   @map("case_id") @db.Uuid
  eventType       String   @map("event_type")
  payload         Json     @default("{}")
  createdByUserId String?  @map("created_by_user_id") @db.Uuid
  occurredAt      DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case      DelinquencyCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("DelinquencyCaseEventCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([caseId, occurredAt])
  @@map("delinquency_case_events")
}

/// Evidencias del expediente en MinIO privado (patrón inspection photos).
model DelinquencyCaseFile {
  id              String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  caseId          String   @map("case_id") @db.Uuid
  kind            String
  objectKey       String   @map("object_key")
  contentType     String?  @map("content_type")
  createdByUserId String?  @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case      DelinquencyCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("DelinquencyCaseFileCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([caseId, createdAt])
  @@map("delinquency_case_files")
}

/// Catálogo global de add-ons facturables del SaaS (lo gestiona el super admin).
model SubscriptionAddon {
  id               String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug             String   @unique
  name             String
  description      String?
  priceMonthly     Decimal  @map("price_monthly") @db.Decimal(12, 2)
  /// Feature que se activa (override) al asignar; null = solo cobra.
  feature          String?
  grantsUnits      Int?     @map("grants_units")
  grantsFacilities Int?     @map("grants_facilities")
  grantsUsers      Int?     @map("grants_users")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenantAddons TenantSubscriptionAddon[]

  @@map("subscription_addons")
}

/// Add-on contratado por un tenant (precio congelado al asignar).
model TenantSubscriptionAddon {
  id           String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  addonId      String    @map("addon_id") @db.Uuid
  priceMonthly Decimal   @map("price_monthly") @db.Decimal(12, 2)
  quantity     Int       @default(1)
  notes        String?
  nextChargeAt DateTime? @map("next_charge_at") @db.Timestamptz(6)
  suspendedAt  DateTime? @map("suspended_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  addon  SubscriptionAddon @relation(fields: [addonId], references: [id], onDelete: Cascade)

  @@unique([tenantId, addonId])
  @@index([tenantId])
  @@map("tenant_subscription_addons")
}
