// Esquema Prisma de StorageOS.
//
// En Fase 0 se incluye únicamente el modelo `Tenant` para validar el flujo
// end-to-end (Prisma <-> Postgres a través de docker-compose). El modelo
// completo de tenancy (users, subscriptions, plans, etc.) se añade en Fase 1
// según `docs/DATA_MODEL.md`.
//
// Nota sobre IDs: el modelo de datos prevé UUID v7. Por simplicidad, en
// Fase 0 usamos `uuid()` (v4). Se migrará a v7 en Fase 1 con una extensión
// Postgres o cliente que lo soporte.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("tenants")
}
