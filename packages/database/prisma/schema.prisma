/// emitidas (obligacion fiscal); anonimiza el customer manteniendo el
/// historial.
model DataSubjectRequest {
  id              String                   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId        String                   @map("tenant_id") @db.Uuid
  customerId      String?                  @map("customer_id") @db.Uuid
  email           String
  requestType     DataSubjectRequestType   @map("request_type")
  status          DataSubjectRequestStatus @default(open)
  submittedAt     DateTime                 @default(now()) @map("submitted_at") @db.Timestamptz(6)
  dueAt           DateTime                 @map("due_at") @db.Timestamptz(6)
  fulfilledAt     DateTime?                @map("fulfilled_at") @db.Timestamptz(6)
  notes           String?
  handledByUserId String?                  @map("handled_by_user_id") @db.Uuid
  exportFileUrl   String?                  @map("export_file_url")
