  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  handledBy User?  @relation("DataRequestHandledBy", fields: [handledByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status, dueAt])
  @@map("data_subject_requests")
}

