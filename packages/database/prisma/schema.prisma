// Esquema Prisma de StorageOS.
//
// Fase 1A: núcleo de tenancy (tenants, users, planes, suscripciones, audit_logs).
// El resto del modelo (facilities, units, contracts, invoices, ...) llega en
// las fases siguientes según docs/DATA_MODEL.md.
//
// Convenciones:
//   - Tablas en snake_case (mediante @map/@@map).
//   - IDs: UUID v7 generados por la función SQL `uuid_generate_v7()` (creada en
//     una migración previa). Permite ordenación cronológica e índices más
//     eficientes que UUID v4.
//   - Timestamps: `timestamptz(6)`, UTC en BD; conversión a timezone del
//     facility en la capa de presentación.
//   - Multi-tenancy: toda tabla con datos de cliente lleva `tenant_id` con
//     índice y queda bajo Row-Level Security (políticas en migración aparte).
//     `subscription_plans` es global y NO lleva RLS.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Enums
// ============================================================================

enum TenantStatus {
  trial
  active
  suspended
  cancelled

  @@map("tenant_status")
}

enum UserRole {
  owner
  manager
  staff
  readonly

  @@map("user_role")
}

enum SubscriptionStatus {
  trial
  active
  past_due
  cancelled
  expired

  @@map("subscription_status")
}

enum UnitStatus {
  available
  occupied
  reserved
  maintenance
  blocked

  @@map("unit_status")
}

enum CustomerType {
  individual
  business

  @@map("customer_type")
}

enum CustomerDocumentType {
  id_front
  id_back
  proof_of_address
  other

  @@map("customer_document_type")
}

enum ContractStatus {
  draft
  active
  ending
  ended
  cancelled

  @@map("contract_status")
}

enum ContractBillingCycle {
  monthly
  weekly
  daily

  @@map("contract_billing_cycle")
}

enum ContractDepositStatus {
  none
  held
  returned
  partially_returned

  @@map("contract_deposit_status")
}

enum ContractEventType {
  created
  signed
  price_changed
  unit_changed
  paused
  resumed
  ending_requested
  ended
  cancelled
  note_added

  @@map("contract_event_type")
}

enum ReservationStatus {
  pending
  confirmed
  expired
  converted
  cancelled

  @@map("reservation_status")
}

enum InvoiceStatus {
  draft
  issued
  paid
  overdue
  cancelled
  refunded
  partially_refunded

  @@map("invoice_status")
}

enum VerifactuMode {
  verifactu
  no_verifactu

  @@map("verifactu_mode")
}

/// Tipo de factura segun spec AEAT Veri*Factu.
/// - F1: factura completa (normal).
/// - F2: factura simplificada (declarada en enum, post-MVP).
/// - R1: rectificativa por error fundado en derecho (mas comun).
/// - R2: rectificativa art. 80.3 LIVA (concurso de acreedores).
/// - R3: rectificativa art. 80.4 LIVA (creditos incobrables).
/// - R4: rectificativa art. 80.6 LIVA (generica).
/// - R5: rectificativa otros motivos (descuentos por volumen, etc.).
enum InvoiceType {
  F1
  F2
  R1
  R2
  R3
  R4
  R5

  @@map("invoice_type")
}

/// Metodo de rectificacion. En MVP solo soportamos `by_differences`.
enum CorrectionMethod {
  by_differences
  by_substitution

  @@map("correction_method")
}

enum AeatStatus {
  pending
  accepted
  accepted_with_warnings
  rejected
  error

  @@map("aeat_status")
}

enum PaymentStatus {
  pending
  processing
  succeeded
  failed
  refunded
  partially_refunded

  @@map("payment_status")
}

enum PaymentMethodType {
  card
  sepa_debit
  bank_transfer
  cash
  other

  @@map("payment_method_type")
}

enum PaymentGatewayProvider {
  stripe
  gocardless
  redsys
  manual

  @@map("payment_gateway_provider")
}

enum DunningActionType {
  email_reminder
  sms_reminder
  late_fee
  access_block
  legal_notice

  @@map("dunning_action_type")
}

enum DunningActionStatus {
  scheduled
  executed
  failed
  cancelled

  @@map("dunning_action_status")
}

enum PricingRuleScope {
  unit
  unit_type
  facility
  tenant

  @@map("pricing_rule_scope")
}

enum PricingRuleType {
  seasonal
  occupancy_based
  duration_discount
  custom

  @@map("pricing_rule_type")
}

enum PriceModifierType {
  percentage
  fixed

  @@map("price_modifier_type")
}

enum PromotionDiscountType {
  percentage
  fixed
  free_months

  @@map("promotion_discount_type")
}

enum DataSubjectRequestType {
  access
  rectification
  erasure
  portability
  restriction

  @@map("data_subject_request_type")
}

enum DataSubjectRequestStatus {
  open
  in_progress
  fulfilled
  denied

  @@map("data_subject_request_status")
}

// ============================================================================
// Modelos
// ============================================================================

/// Empresas clientes del SaaS.
model Tenant {
  id                          String                @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  name                        String
  slug                        String                @unique
  status                      TenantStatus          @default(trial)
  billingExempt               Boolean               @default(false) @map("billing_exempt")
  trialEndsAt                 DateTime?             @map("trial_ends_at") @db.Timestamptz(6)
  billingEmail                String?               @map("billing_email")
  country                     String                @default("ES") @db.Char(2)
  locale                      String                @default("es-ES")
  currency                    String                @default("EUR") @db.Char(3)
  timezone                    String                @default("Europe/Madrid")
  taxId                       String?               @map("tax_id")
  ltvTier                     String?               @map("ltv_tier")
  strategicNotes              String?               @map("strategic_notes")
  tags                        String[]              @default([])
  churnReason                 String?               @map("churn_reason")
  canceledAt                  DateTime?             @map("canceled_at") @db.Timestamptz(6)
  requireTwoFactorForManagers Boolean               @default(false) @map("require_two_factor_for_managers")
  /// Si true, al emitir una factura se intenta cobrar automaticamente al
  /// metodo de pago predeterminado del cliente (cola BullMQ `payments`).
  autoChargeOnIssue           Boolean               @default(false) @map("auto_charge_on_issue")
  autoChargeRetryEnabled      Boolean               @default(false) @map("auto_charge_retry_enabled")
  autoChargeRetryMax          Int                   @default(3) @map("auto_charge_retry_max")
  autoChargeRetryIntervalDays Int                   @default(3) @map("auto_charge_retry_interval_days")
  /// Emite automáticamente las facturas recurrentes (opt-in) en vez de dejarlas
  /// en borrador para revisión manual.
  autoIssueRecurring          Boolean               @default(false) @map("auto_issue_recurring")
  /// Recargo por mora (opt-in): a los `lateFeeGraceDays` de vencimiento se
  /// emite una factura de recargo (% del vencido o € fijo) vía el dunning.
  lateFeeEnabled              Boolean               @default(false) @map("late_fee_enabled")
  /// percentage | fixed
  lateFeeType                 String                @default("percentage") @map("late_fee_type")
  lateFeeValue                Decimal               @default(5) @map("late_fee_value") @db.Decimal(10, 2)
  lateFeeGraceDays            Int                   @default(7) @map("late_fee_grace_days")
  /// Si true, un cron pide la valoracion (NPS) automaticamente N dias tras
  /// firmar el contrato. Opt-in para no enviar emails por sorpresa.
  reviewsAutoRequest          Boolean               @default(false) @map("reviews_auto_request")
  rentIncreaseMaxAnnualPct    Decimal               @default(0) @map("rent_increase_max_annual_pct") @db.Decimal(5, 2)
  rentIncreaseMinMonthsBetween Int                  @default(12) @map("rent_increase_min_months_between")
  reviewRequestDelayDays      Int                   @default(14) @map("review_request_delay_days")
  /// Link de "deja tu reseña" en Google Business Profile; se ofrece al promotor
  /// (NPS >= 9) tras valorar, para mejorar el ranking local.
  googleReviewUrl             String?               @map("google_review_url")
  /// Programa de referidos (opt-in): al convertir un referido se genera una
  /// promocion de un solo uso para el referidor con esta recompensa.
  referralEnabled             Boolean               @default(false) @map("referral_enabled")
  referralRewardType          PromotionDiscountType @default(fixed) @map("referral_reward_type")
  referralRewardValue         Decimal               @default(0) @map("referral_reward_value") @db.Decimal(10, 2)
  extraAccessLimit            Int                   @default(2) @map("extra_access_limit")
  /// White-label del portal del inquilino: color de marca (hex) y URL del logo.
  portalBrandColor            String?               @map("portal_brand_color")
  portalLogoUrl               String?               @map("portal_logo_url")
  customDomain                String?               @unique @map("custom_domain")
  customDomainVerifiedAt      DateTime?             @map("custom_domain_verified_at") @db.Timestamptz(6)
  nightPassEnabled            Boolean               @default(false) @map("night_pass_enabled")
  nightPassPrice              Decimal               @default(0) @map("night_pass_price") @db.Decimal(10, 2)
  collectionsEnabled          Boolean               @default(false) @map("collections_enabled")
  collectionsOpenAfterDays    Int                   @default(30) @map("collections_open_after_days")
  collectionsNoticeDays       Int                   @default(15) @map("collections_notice_days")
  collectionsClauseRef        String?               @map("collections_clause_ref")
  deletedAt                   DateTime?             @map("deleted_at") @db.Timestamptz(6)
  createdAt                   DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  users                   User[]
  tenantRoles             TenantRole[]
  subscription            TenantSubscription?
  subscriptionPayments    TenantSubscriptionPayment[]
  mrrSnapshots            MrrSnapshot[]
  tenantInteractions      TenantInteraction[]
  tenantLifecycleEmails   TenantLifecycleEmail[]
  customerFollowups       CustomerFollowup[]
  cashClosures            CashClosure[]
  featureOverrides        TenantFeatureOverride[]
  tenantFollowups         TenantFollowup[]
  auditLogs               AuditLog[]
  sessions                Session[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  invitations             Invitation[]
  facilities              Facility[]
  unitTypes               UnitType[]
  units                   Unit[]
  unitStatusHistory       UnitStatusHistory[]
  customers               Customer[]
  customerDocuments       CustomerDocument[]
  contracts               Contract[]
  contractEvents          ContractEvent[]
  contractSignatures      ContractSignature[]
  reservations            Reservation[]
  invoiceSeries           InvoiceSeries[]
  invoices                Invoice[]
  invoiceItems            InvoiceItem[]
  payments                Payment[]
  paymentMethods          PaymentMethod[]
  dunningActions          DunningAction[]
  pricingRules            PricingRule[]
  promotions              Promotion[]
  dataSubjectRequests     DataSubjectRequest[]
  consents                Consent[]
  leads                   Lead[]
  messageTemplates        MessageTemplate[]
  communications          Communication[]
  customerInteractions    CustomerInteraction[]
  customerMessages        CustomerMessage[]
  automationRules         AutomationRule[]
  automationRuns          AutomationRun[]
  tasks                   Task[]
  maintenancePlans        MaintenancePlan[]
  taskComments            TaskComment[]
  incidents               Incident[]
  incidentComments        IncidentComment[]
  products                Product[]
  productStocks           ProductStock[]
  productSales            ProductSale[]
  productSaleItems        ProductSaleItem[]
  reportRuns              ReportRun[]
  accessCredentials       AccessCredential[]
  accessDevices           AccessDevice[]
  accessLogs              AccessLog[]
  supportTickets          SupportTicket[]
  impersonationLogs       ImpersonationLog[]
  aeatCredentials         TenantAeatCredential[]
  holdedSettings          HoldedSettings?
  redsysSettings          RedsysSettings?
  redsysOrders            RedsysOrder[]
  goCardlessSettings      GoCardlessSettings?
  notifications           Notification[]
  apiKeys                 ApiKey[]
  webhooks                Webhook[]
  webhookDeliveries       WebhookDelivery[]
  reviews                 Review[]
  referrals               Referral[]
  campaigns               Campaign[]
  rentIncreases           RentIncrease[]
  rentIncreaseItems       RentIncreaseItem[]
  insurancePlans          InsurancePlan[]
  sepaSettings            SepaSettings?
  sepaMandates            SepaMandate[]
  sepaRemittances         SepaRemittance[]
  sepaRemittanceItems     SepaRemittanceItem[]
  bankStatements          BankStatement[]
  bankStatementTxs        BankStatementTransaction[]
  aiConversations         AiConversation[]
  aiMessages              AiMessage[]
  pushSubscriptions       PushSubscription[]
  faqEntries              FaqEntry[]
  unitChangeRequests      UnitChangeRequest[]
  unitRequests            UnitRequest[]
  waitlistEntries         WaitlistEntry[]
  competitorFacilities    CompetitorFacility[]
  platformInvoices        PlatformInvoice[]
  platformDunningEvents   PlatformDunningEvent[]
  userFacilities          UserFacility[]
  inspectionPhotos        ContractInspectionPhoto[]
  delinquencyCases        DelinquencyCase[]
  retentionOffers         RetentionOffer[]
  delinquencyCaseEvents   DelinquencyCaseEvent[]
  delinquencyCaseFiles    DelinquencyCaseFile[]
  subscriptionAddons      TenantSubscriptionAddon[]

  // Índices para las queries cross-tenant del panel admin (filtros omnipresentes
  // por estado/borrado + ventanas temporales de métricas/cohortes/trials).
  @@index([deletedAt, status])
  @@index([status, trialEndsAt])
  @@index([deletedAt, createdAt])
  @@index([status, updatedAt])
  @@map("tenants")
}

/// Staff interno del tenant.
model User {
  id                              String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId                        String    @map("tenant_id") @db.Uuid
  email                           String
  passwordHash                    String    @map("password_hash")
  fullName                        String    @map("full_name")
  phone                           String?
  role                            UserRole  @default(staff)
  /// Rol personalizado del tenant (opcional). Si está, sus permisos sustituyen
  /// a los del `role` enum para los endpoints @RequirePermission y la UI; el
  /// `role` enum se mantiene como base para los endpoints @Roles. Ver ADR-RBAC.
  tenantRoleId                    String?   @map("tenant_role_id") @db.Uuid
  emailVerifiedAt                 DateTime? @map("email_verified_at") @db.Timestamptz(6)
  twoFactorSecretEncrypted        String?   @map("two_factor_secret")
  twoFactorPendingSecretEncrypted String?   @map("two_factor_pending_secret")
  twoFactorEnabled                Boolean   @default(false) @map("two_factor_enabled")
  twoFactorEnrolledAt             DateTime? @map("two_factor_enrolled_at") @db.Timestamptz(6)
  lastLoginAt                     DateTime? @map("last_login_at") @db.Timestamptz(6)
  isActive                        Boolean   @default(true) @map("is_active")
  createdAt                       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant                   Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  tenantRole               TenantRole?               @relation("UserTenantRole", fields: [tenantRoleId], references: [id], onDelete: SetNull)
  auditLogs                AuditLog[]
  sessions                 Session[]
  emailVerificationTokens  EmailVerificationToken[]
  passwordResetTokens      PasswordResetToken[]
  invitationsSent          Invitation[]              @relation("InvitationInviter")
  recoveryCodes            RecoveryCode[]
  unitStatusChanges        UnitStatusHistory[]       @relation("UnitStatusChangedBy")
  customerDocsUploaded     CustomerDocument[]        @relation("DocUploadedBy")
  contractEvents           ContractEvent[]           @relation("ContractEventCreatedBy")
  dataRequestsHandled      DataSubjectRequest[]      @relation("DataRequestHandledBy")
  leadsAssigned            Lead[]                    @relation("LeadAssignedTo")
  tasksAssigned            Task[]                    @relation("TaskAssignedTo")
  tasksCreated             Task[]                    @relation("TaskCreatedBy")
  maintenancePlansAssigned MaintenancePlan[]         @relation("MaintenancePlanAssignee")
  taskCommentsAuthored     TaskComment[]             @relation("TaskCommentAuthor")
  incidentsAssigned        Incident[]                @relation("IncidentAssignedTo")
  incidentsReported        Incident[]                @relation("IncidentReportedBy")
  incidentCommentsAuthored IncidentComment[]         @relation("IncidentCommentAuthor")
  productSalesMade         ProductSale[]             @relation("ProductSaleSoldBy")
  reportRunsTriggered      ReportRun[]               @relation("ReportRunTriggeredBy")
  supportTicketsCreated    SupportTicket[]           @relation("TicketCreatedBy")
  supportMessagesAuthored  SupportTicketMessage[]    @relation("MessageAuthorUser")
  aeatCredentialsUploaded  TenantAeatCredential[]    @relation("AeatCredentialUploadedBy")
  apiKeysCreated           ApiKey[]                  @relation("ApiKeyCreatedBy")
  aiConversations          AiConversation[]
  facilities               UserFacility[]
  inspectionPhotos         ContractInspectionPhoto[]
  customerInteractions     CustomerInteraction[]     @relation("CustomerInteractionAuthor")
  customerMessages         CustomerMessage[]         @relation("CustomerMessageSender")
  customerFollowups        CustomerFollowup[]        @relation("CustomerFollowupAuthor")
  cashClosures             CashClosure[]             @relation("CashClosureAuthor")
  delinquencyCasesOpened   DelinquencyCase[]         @relation("DelinquencyCaseOpenedBy")
  retentionOffers          RetentionOffer[]
  delinquencyCaseEvents    DelinquencyCaseEvent[]    @relation("DelinquencyCaseEventCreatedBy")
  delinquencyCaseFiles     DelinquencyCaseFile[]     @relation("DelinquencyCaseFileCreatedBy")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

/// Permisos por local: a qué facilities está restringido un usuario. Sin filas
/// = sin restricción (ve todos los locales). Con filas = solo esos.
model UserFacility {
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  facilityId String   @map("facility_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([userId, facilityId])
  @@index([tenantId, userId])
  @@map("user_facilities")
}

/// Rol personalizado por tenant (RBAC de grano fino, v1). Define un conjunto
/// de permisos `recurso:accion` (ver `packages/shared/src/auth/permissions.ts`)
/// y un `base_role` enum de respaldo para los endpoints que aún autorizan por
/// `@Roles`. Se asigna a usuarios vía `users.tenant_role_id`.
model TenantRole {
  id          String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  description String?
  /// Lista de permisos del catálogo (`Permission[]`).
  permissions String[] @default([])
  /// Rol enum de respaldo para los endpoints `@Roles`.
  baseRole    UserRole @default(staff) @map("base_role")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users  User[] @relation("UserTenantRole")

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("tenant_roles")
}

/// Codigos de recuperacion para 2FA. Se generan 10 al activar 2FA; solo se
/// devuelven en plaintext una vez. Cada codigo es single-use (used_at).
/// Regenerar todos los codigos invalida los anteriores (delete + insert).
model RecoveryCode {
  id        String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  codeHash  String    @map("code_hash")
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, usedAt])
  @@map("recovery_codes")
}

/// Planes comerciales del SaaS (globales, sin tenant).
model SubscriptionPlan {
  id             String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  name           String
  slug           String   @unique
  priceMonthly   Decimal  @map("price_monthly") @db.Decimal(10, 2)
  priceYearly    Decimal  @map("price_yearly") @db.Decimal(10, 2)
  maxUnits       Int?     @map("max_units")
  maxFacilities  Int?     @map("max_facilities")
  maxUsers       Int?     @map("max_users")
  features       Json     @default("{}")
  /// Features premium gateadas por este plan (editable desde /admin/plans).
  tenantFeatures String[] @map("tenant_features")
  stripePriceId  String?  @map("stripe_price_id")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  subscriptions TenantSubscription[]

  @@map("subscription_plans")
}

/// Snapshot mensual del MRR de cada tenant (1 fila por tenant y mes). Permite
/// calcular los MRR movements (new/expansion/contraction/churn/reactivation)
/// comparando meses consecutivos. Lo escribe un cron mensual + captura
/// on-demand del mes en curso + backfill desde el historial de pagos.
model MrrSnapshot {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  /// Primer día del mes (UTC) que representa el snapshot.
  month     DateTime @db.Date
  planSlug  String   @map("plan_slug")
  status    String
  /// MRR mensual normalizado (priceMonthly del plan en ese mes).
  mrr       Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, month])
  @@index([month])
  @@map("mrr_snapshots")
}

/// Suscripción activa de cada tenant.
model TenantSubscription {
  id                   String             @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId             String             @unique @map("tenant_id") @db.Uuid
  planId               String             @map("plan_id") @db.Uuid
  status               SubscriptionStatus @default(trial)
  currentPeriodStart   DateTime           @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd     DateTime           @map("current_period_end") @db.Timestamptz(6)
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  /// Días de crédito concedidos por pagos manuales (acumulador permanente). El
  /// periodo efectivo = fecha de Stripe + estos días; así un pago manual se
  /// SUMA al cobro de Stripe en vez de pisarse.
  manualExtensionDays  Int                @default(0) @map("manual_extension_days")
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  plan   SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@map("tenant_subscriptions")
}

/// Registro inmutable de acciones críticas. Sobrevive al borrado de usuarios.
model AuditLog {
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  changes    Json     @default("{}")
  ipAddress  String?  @map("ip_address") @db.Inet
  userAgent  String?  @map("user_agent")
  occurredAt DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, occurredAt(sort: Desc)])
  @@map("audit_logs")
}

/// Sesion de refresh. Cada login emite una sesion; cada refresh rota la
/// actual y crea otra (`rotatedFromId` apunta a la anterior). Si una sesion
/// ya revocada o rotada se intenta reusar, revocamos todas las del usuario
/// (politica paranoid; ver SessionsService).
model Session {
  id               String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address") @db.Inet
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  lastUsedAt       DateTime  @default(now()) @map("last_used_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  revokedReason    String?   @map("revoked_reason")
  rotatedFromId    String?   @map("rotated_from_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("sessions")
}

/// Token de verificacion de email enviado tras el registro o un resend.
/// Single-use; el plaintext (formato `<id>.<secret>`) viaja en el enlace
/// del email; solo el hash argon2id del secret se guarda aqui.
model EmailVerificationToken {
  id        String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, usedAt])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

/// Token de recuperacion de contrasena. Misma estructura que el de email
/// verification, mas metadatos del request para auditoria. TTL mas corto.
model PasswordResetToken {
  id                 String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  tokenHash          String    @map("token_hash")
  expiresAt          DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt             DateTime? @map("used_at") @db.Timestamptz(6)
  requestedIp        String?   @map("requested_ip") @db.Inet
  requestedUserAgent String?   @map("requested_user_agent")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, usedAt])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

/// Invitacion para que un email externo se una al tenant con un role. El
/// invitado fija su propia password al aceptar; el email queda verificado
/// implicitamente. Single-use (accepted_at). Revocable (revoked_at). Solo
/// puede haber una invitacion pendiente por (tenant, email): se garantiza
/// con un indice unico parcial creado en SQL en la migracion 1E_rls.
model Invitation {
  id              String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  email           String
  role            UserRole
  invitedByUserId String?   @map("invited_by_user_id") @db.Uuid
  tokenHash       String    @map("token_hash")
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz(6)
  acceptedAt      DateTime? @map("accepted_at") @db.Timestamptz(6)
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz(6)
  revokedReason   String?   @map("revoked_reason")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  invitedBy User?  @relation("InvitationInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([expiresAt])
  @@map("invitations")
}

/// Local fisico del tenant. Cada facility tiene N floors y N units. Soft
/// delete (`deleted_at`) porque borrar implicaria perder historial de
/// contratos asociados a sus units (Fase 3).
model Facility {
  id                  String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  name                String
  /// Slug público para la landing SEO por local (`/s/<tenant>/<slug>`). Único
  /// por tenant. Se genera del nombre al crear; null en casos sin slug válido.
  publicSlug          String?   @map("public_slug")
  address             String?
  city                String?
  postalCode          String?   @map("postal_code")
  country             String    @default("ES") @db.Char(2)
  latitude            Decimal?  @db.Decimal(9, 6)
  longitude           Decimal?  @db.Decimal(9, 6)
  timezone            String    @default("Europe/Madrid")
  openingHours        Json      @default("{}") @map("opening_hours")
  /// Toque de queda de acceso: franja "HH:MM"-"HH:MM" (en `timezone`) en la que
  /// se bloquea el acceso, salvo credenciales con `bypassCurfew`.
  accessCurfewEnabled Boolean   @default(false) @map("access_curfew_enabled")
  accessCurfewStart   String?   @map("access_curfew_start")
  accessCurfewEnd     String?   @map("access_curfew_end")
  contactPhone        String?   @map("contact_phone")
  contactEmail        String?   @map("contact_email")
  /// Keys de objeto MinIO de las imágenes del local (landing pública). El
  /// servidor construye las URLs con `FilesService.buildPublicUrl`.
  images              String[]  @default([])
  isActive            Boolean   @default(true) @map("is_active")
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  floors               FacilityFloor[]
  units                Unit[]
  unitRequests         UnitRequest[]
  waitlistEntries      WaitlistEntry[]
  competitorFacilities CompetitorFacility[]
  leadsPreferred       Lead[]               @relation("LeadPreferredFacility")
  tasks                Task[]               @relation("TaskFacility")
  maintenancePlans     MaintenancePlan[]
  incidents            Incident[]           @relation("IncidentFacility")
  productStocks        ProductStock[]       @relation("ProductStockFacility")
  productSales         ProductSale[]        @relation("ProductSaleFacility")
  accessDevices        AccessDevice[]       @relation("DeviceFacility")
  userFacilities       UserFacility[]
  cashClosures         CashClosure[]

  @@unique([tenantId, publicSlug])
  @@index([tenantId])
  @@index([tenantId, isActive, deletedAt])
  @@map("facilities")
}

/// Plantas dentro de un local. Cada facility puede tener 0..N floors. Si
/// el tenant no crea ninguna, el servicio garantiza una "default floor"
/// automatica al crear la primera unit. Las units siempre apuntan a una
/// floor concreta.
model FacilityFloor {
  id           String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  facilityId   String   @map("facility_id") @db.Uuid
  name         String
  floorNumber  Int      @default(0) @map("floor_number")
  planImageUrl String?  @map("plan_image_url")
  planWidthPx  Int?     @map("plan_width_px")
  planHeightPx Int?     @map("plan_height_px")
  /// true = creada automaticamente al primer unit, no por el usuario.
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Restrict)
  units    Unit[]

  @@index([facilityId])
  @@map("facility_floors")
}

/// Tipologia de trastero (S/M/L/XL...) a nivel de tenant. Las units
/// referencian un unit_type para heredar color, precio por defecto y
/// features. Cambiar features de un unit_type NO modifica las units
/// existentes (snapshot en `units.base_price_monthly`).
model UnitType {
  id                   String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  name                 String
  description          String?
  defaultPriceMonthly  Decimal  @map("default_price_monthly") @db.Decimal(10, 2)
  defaultDepositAmount Decimal  @default(0) @map("default_deposit_amount") @db.Decimal(10, 2)
  color                String   @default("#888888") @db.Char(7)
  features             Json     @default("{}")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  units           Unit[]
  unitRequests    UnitRequest[]
  waitlistEntries WaitlistEntry[]
  leadsPreferred  Lead[]          @relation("LeadPreferredUnitType")

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("unit_types")
}

/// Trastero individual. `area_m2` y `volume_m3` son columnas generadas en
/// Postgres (GENERATED ALWAYS AS ... STORED) para coherencia: nunca se
/// settean desde la app. Su DDL vive en la migracion 2A_facilities porque
/// Prisma no las modela (`@@ignore` no aplica aqui).
model Unit {
  id               String     @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId         String     @map("tenant_id") @db.Uuid
  facilityId       String     @map("facility_id") @db.Uuid
  floorId          String     @map("floor_id") @db.Uuid
  unitTypeId       String     @map("unit_type_id") @db.Uuid
  code             String
  widthM           Decimal    @map("width_m") @db.Decimal(6, 2)
  depthM           Decimal    @map("depth_m") @db.Decimal(6, 2)
  heightM          Decimal    @map("height_m") @db.Decimal(6, 2)
  /// Columnas generadas en Postgres. Prisma las lee pero no las escribe.
  areaM2           Decimal?   @map("area_m2") @db.Decimal(10, 4)
  volumeM3         Decimal?   @map("volume_m3") @db.Decimal(12, 4)
  status           UnitStatus @default(available)
  basePriceMonthly Decimal    @map("base_price_monthly") @db.Decimal(10, 2)
  planX            Decimal?   @map("plan_x") @db.Decimal(10, 3)
  planY            Decimal?   @map("plan_y") @db.Decimal(10, 3)
  planWidth        Decimal?   @map("plan_width") @db.Decimal(10, 3)
  planHeight       Decimal?   @map("plan_height") @db.Decimal(10, 3)
  planShape        Json?      @map("plan_shape")
  notes            String?
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  facility         Facility            @relation(fields: [facilityId], references: [id], onDelete: Restrict)
  floor            FacilityFloor       @relation(fields: [floorId], references: [id], onDelete: Restrict)
  unitType         UnitType            @relation(fields: [unitTypeId], references: [id], onDelete: Restrict)
  statusHistory    UnitStatusHistory[]
  contracts        Contract[]
  unitRequests     UnitRequest[]
  reservations     Reservation[]
  tasks            Task[]              @relation("TaskUnit")
  incidents        Incident[]          @relation("IncidentUnit")
  accessDevices    AccessDevice[]      @relation("DeviceUnit")
  delinquencyCases DelinquencyCase[]

  @@unique([facilityId, code])
  @@index([tenantId])
  @@index([facilityId, status])
  @@index([floorId])
  @@map("units")
}

/// Historial de cambios de estado de cada unit. Inmutable. Se inserta
/// desde `UnitsService.changeStatus`. Permite reconstruir la timeline
/// de un trastero (cuando estuvo ocupado, en mantenimiento, etc.).
model UnitStatusHistory {
  id              String     @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId        String     @map("tenant_id") @db.Uuid
  unitId          String     @map("unit_id") @db.Uuid
  previousStatus  UnitStatus @map("previous_status")
  newStatus       UnitStatus @map("new_status")
  changedByUserId String?    @map("changed_by_user_id") @db.Uuid
  reason          String?
  occurredAt      DateTime   @default(now()) @map("occurred_at") @db.Timestamptz(6)

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  unit      Unit   @relation(fields: [unitId], references: [id], onDelete: Restrict)
  changedBy User?  @relation("UnitStatusChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([unitId, occurredAt(sort: Desc)])
  @@map("unit_status_history")
}

/// Inquilino del tenant. Individuo o empresa que alquila trasteros.
/// Soft delete (`deleted_at`) porque borrar implicaria perder historial
/// de contratos y facturas (Fase 4). El email puede ser NULL: hay
/// inquilinos sin email (efectivo, walk-in). El `document_number` es la
/// identidad legal (DNI/NIE/CIF) y NO es unico globalmente (un mismo
/// DNI puede repetirse entre tenants).
model Customer {
  id                    String       @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId              String       @map("tenant_id") @db.Uuid
  customerType          CustomerType @default(individual) @map("customer_type")
  firstName             String?      @map("first_name")
  lastName              String?      @map("last_name")
  companyName           String?      @map("company_name")
  documentType          String?      @map("document_type")
  documentNumber        String?      @map("document_number")
  email                 String?
  phone                 String?
  address               String?
  city                  String?
  postalCode            String?      @map("postal_code")
  country               String       @default("ES") @db.Char(2)
  emergencyContactName  String?      @map("emergency_contact_name")
  emergencyContactPhone String?      @map("emergency_contact_phone")
  notes                 String?
  tags                  String[]     @default([])
  portalAccessEnabled   Boolean      @default(false) @map("portal_access_enabled")
  portalPasswordHash    String?      @map("portal_password_hash")
  kycVerified           Boolean      @default(false) @map("kyc_verified")
  kycVerifiedAt         DateTime?    @map("kyc_verified_at") @db.Timestamptz(6)
  /// Codigo de referido que este cliente comparte (unico por tenant).
  referralCode          String?      @map("referral_code")
  deletedAt             DateTime?    @map("deleted_at") @db.Timestamptz(6)
  createdAt             DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  documents          CustomerDocument[]
  contracts          Contract[]
  reservations       Reservation[]
  invoices           Invoice[]
  payments           Payment[]
  paymentMethods     PaymentMethod[]
  consents           Consent[]
  communications     Communication[]
  leadsConverted     Lead[]                @relation("LeadConvertedCustomer")
  incidents          Incident[]            @relation("IncidentCustomer")
  productSales       ProductSale[]         @relation("ProductSaleCustomer")
  credentials        AccessCredential[]    @relation("CredentialCustomer")
  accessLogs         AccessLog[]           @relation("AccessLogCustomer")
  reviews            Review[]
  referralsMade      Referral[]            @relation("ReferralReferrer")
  referralReceived   Referral?             @relation("ReferralReferred")
  sepaMandates       SepaMandate[]
  pushSubscriptions  PushSubscription[]
  unitChangeRequests UnitChangeRequest[]
  unitRequests       UnitRequest[]
  waitlistEntries    WaitlistEntry[]
  interactions       CustomerInteraction[]
  messages           CustomerMessage[]
  followups          CustomerFollowup[]
  delinquencyCases   DelinquencyCase[]
  retentionOffers    RetentionOffer[]

  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, documentNumber])
  @@index([tenantId, email])
  @@map("customers")
}

/// Documentos de un inquilino subidos a MinIO. Cada uno con su tipo
/// (DNI front/back, comprobante de domicilio, otros) y metadatos.
model CustomerDocument {
  id               String               @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId         String               @map("tenant_id") @db.Uuid
  customerId       String               @map("customer_id") @db.Uuid
  type             CustomerDocumentType
  fileUrl          String               @map("file_url")
  fileName         String               @map("file_name")
  mimeType         String               @map("mime_type")
  fileSize         Int                  @map("file_size")
  uploadedByUserId String?              @map("uploaded_by_user_id") @db.Uuid
  expiresAt        DateTime?            @map("expires_at") @db.Timestamptz(6)
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  uploadedBy User?    @relation("DocUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([customerId])
  @@map("customer_documents")
}

/// Contrato de alquiler. Estados: draft -> active -> ending -> ended,
/// o draft/active/ending -> cancelled. El `price_monthly` se congela al
/// firmar (snapshot, ver ADR-020); cambios posteriores requieren un
/// `ContractEvent` price_changed. Numero secuencial unico por tenant.
model Contract {
  id                     String                @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId               String                @map("tenant_id") @db.Uuid
  customerId             String                @map("customer_id") @db.Uuid
  unitId                 String                @map("unit_id") @db.Uuid
  contractNumber         String                @map("contract_number")
  status                 ContractStatus        @default(draft)
  startDate              DateTime              @map("start_date") @db.Date
  endDate                DateTime?             @map("end_date") @db.Date
  signedAt               DateTime?             @map("signed_at") @db.Timestamptz(6)
  endingRequestedAt      DateTime?             @map("ending_requested_at") @db.Timestamptz(6)
  endedAt                DateTime?             @map("ended_at") @db.Timestamptz(6)
  cancelledAt            DateTime?             @map("cancelled_at") @db.Timestamptz(6)
  billingCycle           ContractBillingCycle  @default(monthly) @map("billing_cycle")
  /// Precio congelado al firmar (snapshot). Antes de firmar es el
  /// precio propuesto y puede cambiarse libremente. Tras firmar, solo
  /// cambia via ContractEvent price_changed.
  priceMonthly           Decimal               @map("price_monthly") @db.Decimal(10, 2)
  discountAmount         Decimal               @default(0) @map("discount_amount") @db.Decimal(10, 2)
  discountReason         String?               @map("discount_reason")
  discountExpiresAt      DateTime?             @map("discount_expires_at") @db.Timestamptz(6)
  /// Promoción aplicada al alta (si la hubo) + meses gratis pendientes de
  /// consumir (promociones `free_months`); la facturación recurrente emite las
  /// primeras N facturas con el alquiler a 0 y decrementa el contador.
  promotionId            String?               @map("promotion_id") @db.Uuid
  freeMonthsRemaining    Int                   @default(0) @map("free_months_remaining")
  depositAmount          Decimal               @default(0) @map("deposit_amount") @db.Decimal(10, 2)
  depositStatus          ContractDepositStatus @default(none) @map("deposit_status")
  /// Liquidación de la fianza al finalizar: importe devuelto + fecha + motivo de
  /// retención (daños/deuda). `depositStatus` transiciona held→returned/partially_returned.
  depositReturnedAmount  Decimal               @default(0) @map("deposit_returned_amount") @db.Decimal(10, 2)
  depositSettledAt       DateTime?             @map("deposit_settled_at") @db.Timestamptz(6)
  depositRetentionReason String?               @map("deposit_retention_reason")
  signedPdfUrl           String?               @map("signed_pdf_url")
  /// Firma remota: hash del token de firma (argon2) + expiración. Null si no hay solicitud activa.
  signingTokenHash       String?               @map("signing_token_hash")
  signingTokenExpiresAt  DateTime?             @map("signing_token_expires_at") @db.Timestamptz(6)
  /// Marca cuándo se emitió el aviso "vence pronto" (idempotencia del cron).
  endingSoonNotifiedAt   DateTime?             @map("ending_soon_notified_at") @db.Timestamptz(6)
  firstPaymentDeadline   DateTime?             @map("first_payment_deadline") @db.Timestamptz(6)
  autoRenew              Boolean               @default(true) @map("auto_renew")
  cancellationNoticeDays Int                   @default(15) @map("cancellation_notice_days")
  /// Seguro/protección opcional: plan asignado + prima mensual congelada al asignar.
  insurancePlanId        String?               @map("insurance_plan_id") @db.Uuid
  insurancePrice         Decimal?              @map("insurance_price") @db.Decimal(10, 2)
  notes                  String?
  deletedAt              DateTime?             @map("deleted_at") @db.Timestamptz(6)
  createdAt              DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant             Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customer           Customer                  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  unit               Unit                      @relation(fields: [unitId], references: [id], onDelete: Restrict)
  events             ContractEvent[]
  signatures         ContractSignature[]
  invoices           Invoice[]
  invoiceItems       InvoiceItem[]
  leadsConverted     Lead[]                    @relation("LeadConvertedContract")
  incidents          Incident[]                @relation("IncidentContract")
  credentials        AccessCredential[]        @relation("CredentialContract")
  reviews            Review[]
  rentIncreaseItems  RentIncreaseItem[]
  insurancePlan      InsurancePlan?            @relation(fields: [insurancePlanId], references: [id], onDelete: SetNull)
  promotion          Promotion?                @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  unitChangeRequests UnitChangeRequest[]
  inspectionPhotos   ContractInspectionPhoto[]
  delinquencyCases   DelinquencyCase[]
  retentionOffers    RetentionOffer[]

  @@unique([tenantId, contractNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([customerId])
  @@index([unitId])
  @@map("contracts")
}

model RetentionOffer {
  id              String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  contractId      String    @map("contract_id") @db.Uuid
  customerId      String    @map("customer_id") @db.Uuid
  /// percentage | fixed
  discountType    String    @map("discount_type")
  discountValue   Decimal   @map("discount_value") @db.Decimal(10, 2)
  months          Int       @default(1)
  message         String?
  /// pending | accepted | declined | expired
  status          String    @default("pending")
  validUntil      DateTime? @map("valid_until") @db.Timestamptz(6)
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  respondedAt     DateTime? @map("responded_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contract  Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdBy User?    @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, contractId])
  @@index([tenantId, customerId])
  @@map("retention_offers")
}

/// Foto del estado del trastero en una inspección (check-in o check-out) —
/// evidencia para fianzas/disputas. La imagen vive en MinIO (bucket privado
/// `uploads`); aquí solo la key + metadatos. `kind` = 'checkin' | 'checkout'.
model ContractInspectionPhoto {
  id              String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  contractId      String   @map("contract_id") @db.Uuid
  kind            String   @default("checkout")
  key             String
  note            String?
  createdByUserId String?  @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contract  Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  createdBy User?    @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, contractId])
  @@map("contract_inspection_photos")
}

/// Firma electrónica simple de un contrato: registro probatorio (firmante,
/// método, imagen/typed, hash del documento firmado, IP y user-agent).
model ContractSignature {
  id             String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  contractId     String   @map("contract_id") @db.Uuid
  signerName     String   @map("signer_name")
  signerEmail    String?  @map("signer_email")
  /// "drawn" (firma dibujada en pad) | "typed" (nombre tecleado + aceptación)
  method         String
  /// Data URL PNG de la firma dibujada (si method=drawn).
  signatureImage String?  @map("signature_image")
  typedSignature String?  @map("typed_signature")
  /// SHA-256 de los términos firmados (huella de qué se firmó).
  documentHash   String   @map("document_hash")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  /// Canal de firma: "remote" (enlace) | "in_person" (pad asistido) | "self_service" (move-in público)
  channel        String   @default("remote")
  signedAt       DateTime @default(now()) @map("signed_at") @db.Timestamptz(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([contractId])
  @@map("contract_signatures")
}

/// Historial inmutable de eventos de un contrato. Se inserta cada vez
/// que cambia el estado (signed, ended, cancelled), el precio
/// (price_changed) o se anyade una nota. Permite reconstruir la timeline
/// completa para auditoria y soporte.
model ContractEvent {
  id              String            @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId        String            @map("tenant_id") @db.Uuid
  contractId      String            @map("contract_id") @db.Uuid
  eventType       ContractEventType @map("event_type")
  payload         Json              @default("{}")
  createdByUserId String?           @map("created_by_user_id") @db.Uuid
  occurredAt      DateTime          @default(now()) @map("occurred_at") @db.Timestamptz(6)

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  contract  Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("ContractEventCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([contractId, occurredAt(sort: Desc)])
  @@map("contract_events")
}

/// Reserva previa a la firma del contrato. Pre-bloquea un unit durante
/// un periodo. El EXCLUDE constraint con btree_gist garantiza a nivel
/// de BD que no haya solapamiento entre reservas pending/confirmed para
/// el mismo unit. Ver migracion <fecha>_phase3_reservations_exclude.
///
/// `timeRange` es una columna GENERATED de Postgres (tstzrange) cuyo
/// DDL vive en la migracion SQL (Prisma no la modela). El servicio
/// nunca la escribe; solo lee `validFrom`/`validUntil`.
model Reservation {
  id                  String            @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId            String            @map("tenant_id") @db.Uuid
  unitId              String            @map("unit_id") @db.Uuid
  customerId          String?           @map("customer_id") @db.Uuid
  status              ReservationStatus @default(pending)
  validFrom           DateTime          @map("valid_from") @db.Timestamptz(6)
  validUntil          DateTime          @map("valid_until") @db.Timestamptz(6)
  depositPaid         Boolean           @default(false) @map("deposit_paid")
  depositAmount       Decimal           @default(0) @map("deposit_amount") @db.Decimal(10, 2)
  notes               String?
  convertedContractId String?           @map("converted_contract_id") @db.Uuid
  cancelledAt         DateTime?         @map("cancelled_at") @db.Timestamptz(6)
  cancelReason        String?           @map("cancel_reason")
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  unit           Unit      @relation(fields: [unitId], references: [id], onDelete: Restrict)
  customer       Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  leadsConverted Lead[]    @relation("LeadConvertedReservation")

  @@index([tenantId])
  @@index([unitId, status])
  @@index([customerId])
  @@index([validUntil])
  @@map("reservations")
}

/// Serie de numeracion de facturas. Cada tenant puede tener varias
/// (p.ej. una por facility o por año, segun configuracion de IVA y
/// requisitos Verifactu). El `next_number` se incrementa atomicamente
/// al emitir cada factura (UNIQUE en invoices + UPDATE ... RETURNING).
model InvoiceSeries {
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  code       String
  name       String
  prefix     String
  yearScope  Boolean  @default(true) @map("year_scope")
  /// El siguiente numero a usar al emitir. Se actualiza junto con el
  /// invoice INSERT en la misma transaccion.
  nextNumber Int      @default(1) @map("next_number")
  facilityId String?  @map("facility_id") @db.Uuid
  isActive   Boolean  @default(true) @map("is_active")
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  invoices Invoice[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("invoice_series")
}

/// Factura emitida. Verifactu fields:
///   - `hash`: SHA-256 del payload de la factura (RD 1007/2023).
///   - `previous_hash`: hash de la inmediatamente anterior de la misma serie.
///   - `qr_code_url`: URL del QR AEAT (con CSV cuando este disponible).
///   - `verifactu_mode`: declarado por el tenant.
///   - `aeat_*`: estado de envio a AEAT (en Fase 4: stub; en Fase 8: real).
///
/// El `invoice_number` es inmutable tras pasar de `draft` a `issued`. La
/// numeracion secuencial dentro de (tenant, series) la garantiza UNIQUE.
model Invoice {
  id                  String            @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId            String            @map("tenant_id") @db.Uuid
  /// Nullable desde Fase 13A.3: en F2 (factura simplificada) el destinatario
  /// puede no identificarse. En F1 sigue siendo obligatorio (validado en
  /// `InvoicesService.create`, no a nivel de schema).
  customerId          String?           @map("customer_id") @db.Uuid
  contractId          String?           @map("contract_id") @db.Uuid
  seriesId            String            @map("series_id") @db.Uuid
  sequenceNumber      Int               @map("sequence_number")
  invoiceNumber       String            @map("invoice_number")
  status              InvoiceStatus     @default(draft)
  invoiceType         InvoiceType       @default(F1) @map("invoice_type")
  /// Si es una rectificativa (`invoice_type` en R1..R5), apunta a la
  /// factura original que se rectifica. ON DELETE RESTRICT para impedir
  /// borrar la original sin antes resolver la rectificativa.
  rectifiesInvoiceId  String?           @map("rectifies_invoice_id") @db.Uuid
  rectificationReason String?           @map("rectification_reason")
  correctionMethod    CorrectionMethod? @map("correction_method")
  /// Si esta factura es un recargo por mora, apunta a la factura vencida que
  /// lo originó (idempotencia: única por factura original).
  lateFeeForInvoiceId String?           @unique @map("late_fee_for_invoice_id") @db.Uuid
  issueDate           DateTime?         @map("issue_date") @db.Date
  dueDate             DateTime?         @map("due_date") @db.Date
  /// Periodo facturado (p.ej. mes natural si es un alquiler mensual).
  periodStart         DateTime?         @map("period_start") @db.Date
  periodEnd           DateTime?         @map("period_end") @db.Date
  subtotal            Decimal           @default(0) @db.Decimal(12, 2)
  taxAmount           Decimal           @default(0) @map("tax_amount") @db.Decimal(12, 2)
  total               Decimal           @default(0) @db.Decimal(12, 2)
  amountPaid          Decimal           @default(0) @map("amount_paid") @db.Decimal(12, 2)
  amountRefunded      Decimal           @default(0) @map("amount_refunded") @db.Decimal(12, 2)
  autoRetryCount      Int               @default(0) @map("auto_retry_count")
  autoRetryLastAt     DateTime?         @map("auto_retry_last_at") @db.Timestamptz(6)
  currency            String            @default("EUR") @db.Char(3)
  pdfUrl              String?           @map("pdf_url")
  notes               String?
  /// --- Verifactu ---
  hash                String?
  previousHash        String?           @map("previous_hash")
  qrCodeUrl           String?           @map("qr_code_url")
  verifactuMode       VerifactuMode     @default(verifactu) @map("verifactu_mode")
  aeatSentAt          DateTime?         @map("aeat_sent_at") @db.Timestamptz(6)
  aeatStatus          AeatStatus?       @map("aeat_status")
  aeatResponse        Json?             @map("aeat_response")
  aeatCsv             String?           @map("aeat_csv")
  /// Id del documento en Holded si se ha exportado (integración contable).
  holdedDocumentId    String?           @map("holded_document_id")
  paidAt              DateTime?         @map("paid_at") @db.Timestamptz(6)
  cancelledAt         DateTime?         @map("cancelled_at") @db.Timestamptz(6)
  deletedAt           DateTime?         @map("deleted_at") @db.Timestamptz(6)
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant             Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customer           Customer?                  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  contract           Contract?                  @relation(fields: [contractId], references: [id], onDelete: SetNull)
  series             InvoiceSeries              @relation(fields: [seriesId], references: [id], onDelete: Restrict)
  items              InvoiceItem[]
  payments           Payment[]
  dunningActions     DunningAction[]
  productSale        ProductSale?               @relation("ProductSaleInvoice")
  redsysOrders       RedsysOrder[]
  rectifiesInvoice   Invoice?                   @relation("InvoiceRectification", fields: [rectifiesInvoiceId], references: [id], onDelete: Restrict)
  rectifiedBy        Invoice[]                  @relation("InvoiceRectification")
  lateFeeForInvoice  Invoice?                   @relation("InvoiceLateFee", fields: [lateFeeForInvoiceId], references: [id], onDelete: SetNull)
  lateFeeInvoice     Invoice?                   @relation("InvoiceLateFee")
  sepaRemittanceItem SepaRemittanceItem?
  bankStatementTxs   BankStatementTransaction[]

  // La unicidad de numeración vive en SQL como índice PARCIAL (solo
  // sequence_number > 0): los drafts llevan 0 y deben poder convivir.
  // Ver migración 20260702140000 (Prisma no representa índices parciales).
  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([customerId])
  @@index([dueDate])
  @@index([rectifiesInvoiceId])
  @@index([tenantId, issueDate])
  @@map("invoices")
}

/// Linea de factura. `unit_price` snapshot del precio aplicado tras
/// resolver pricing rules y promotions (no se recalcula al recargar).
model InvoiceItem {
  id                String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  invoiceId         String    @map("invoice_id") @db.Uuid
  description       String
  quantity          Decimal   @default(1) @db.Decimal(10, 3)
  unitPrice         Decimal   @map("unit_price") @db.Decimal(12, 2)
  taxRate           Decimal   @default(21) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount         Decimal   @default(0) @map("tax_amount") @db.Decimal(12, 2)
  total             Decimal   @default(0) @db.Decimal(12, 2)
  relatedContractId String?   @map("related_contract_id") @db.Uuid
  relatedUnitId     String?   @map("related_unit_id") @db.Uuid
  periodStart       DateTime? @map("period_start") @db.Date
  periodEnd         DateTime? @map("period_end") @db.Date
  position          Int       @default(0)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  invoice         Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  relatedContract Contract? @relation(fields: [relatedContractId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([invoiceId])
  @@map("invoice_items")
}

/// Pago. Puede asociarse a una invoice o ser standalone (p.ej. fianza
/// inicial sin factura). Sincronizado con el gateway via webhook.
model Payment {
  id               String                 @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId         String                 @map("tenant_id") @db.Uuid
  invoiceId        String?                @map("invoice_id") @db.Uuid
  customerId       String                 @map("customer_id") @db.Uuid
  paymentMethodId  String?                @map("payment_method_id") @db.Uuid
  amount           Decimal                @db.Decimal(12, 2)
  currency         String                 @default("EUR") @db.Char(3)
  status           PaymentStatus          @default(pending)
  methodType       PaymentMethodType      @map("method_type")
  gateway          PaymentGatewayProvider @default(manual)
  gatewayPaymentId String?                @map("gateway_payment_id")
  gatewayResponse  Json?                  @map("gateway_response")
  paidAt           DateTime?              @map("paid_at") @db.Timestamptz(6)
  refundedAt       DateTime?              @map("refunded_at") @db.Timestamptz(6)
  refundedAmount   Decimal                @default(0) @map("refunded_amount") @db.Decimal(12, 2)
  failureReason    String?                @map("failure_reason")
  notes            String?
  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  invoice       Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  customer      Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([invoiceId])
  @@index([customerId])
  @@index([gatewayPaymentId])
  @@index([tenantId, status, paidAt])
  @@map("payments")
}

/// Metodo de pago guardado del cliente. Tokens del gateway cifrados con
/// CryptoService (AES-256-GCM, ADR-007).
model PaymentMethod {
  id                    String                 @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId              String                 @map("tenant_id") @db.Uuid
  customerId            String                 @map("customer_id") @db.Uuid
  type                  PaymentMethodType
  gateway               PaymentGatewayProvider
  /// Cifrado AES-256-GCM. NUNCA en plaintext.
  gatewayTokenEncrypted String                 @map("gateway_token_encrypted")
  /// Id del Customer en el gateway (Stripe customer id, etc.). No es secreto.
  gatewayCustomerId     String?                @map("gateway_customer_id")
  last4                 String?                @db.Char(4)
  brand                 String?
  expMonth              Int?                   @map("exp_month")
  expYear               Int?                   @map("exp_year")
  isDefault             Boolean                @default(false) @map("is_default")
  mandateReference      String?                @map("mandate_reference")
  deletedAt             DateTime?              @map("deleted_at") @db.Timestamptz(6)
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([tenantId])
  @@index([customerId, deletedAt])
  @@map("payment_methods")
}

/// Accion de dunning programada o ejecutada sobre una factura overdue.
model DunningAction {
  id           String              @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId     String              @map("tenant_id") @db.Uuid
  invoiceId    String              @map("invoice_id") @db.Uuid
  actionType   DunningActionType   @map("action_type")
  status       DunningActionStatus @default(scheduled)
  scheduledFor DateTime            @map("scheduled_for") @db.Timestamptz(6)
  executedAt   DateTime?           @map("executed_at") @db.Timestamptz(6)
  result       Json?
  notes        String?
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([invoiceId])
  @@index([scheduledFor, status])
  @@map("dunning_actions")
}

/// Regla de pricing dinamico. `conditions` JSONB describe cuando aplica
/// (rango fechas, ocupacion %, duracion contrato, etc.). `priority`
/// resuelve conflictos (mayor primero).
model PricingRule {
  id            String            @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId      String            @map("tenant_id") @db.Uuid
  name          String
  scope         PricingRuleScope
  targetId      String?           @map("target_id") @db.Uuid
  ruleType      PricingRuleType   @map("rule_type")
  conditions    Json              @default("{}")
  modifierType  PriceModifierType @map("modifier_type")
  modifierValue Decimal           @map("modifier_value") @db.Decimal(10, 2)
  validFrom     DateTime?         @map("valid_from") @db.Timestamptz(6)
  validUntil    DateTime?         @map("valid_until") @db.Timestamptz(6)
  priority      Int               @default(0)
  isActive      Boolean           @default(true) @map("is_active")
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, isActive, scope])
  @@map("pricing_rules")
}

/// Codigo promocional. `applies_to` JSONB describe a que units/types
/// aplica (vacio = todo el catalogo del tenant).
model Promotion {
  id            String                @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId      String                @map("tenant_id") @db.Uuid
  code          String
  name          String
  discountType  PromotionDiscountType @map("discount_type")
  discountValue Decimal               @map("discount_value") @db.Decimal(10, 2)
  appliesTo     Json                  @default("{}") @map("applies_to")
  maxUses       Int?                  @map("max_uses")
  usedCount     Int                   @default(0) @map("used_count")
  validFrom     DateTime?             @map("valid_from") @db.Timestamptz(6)
  validUntil    DateTime?             @map("valid_until") @db.Timestamptz(6)
  isActive      Boolean               @default(true) @map("is_active")
  createdAt     DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  referrals Referral[]
  contracts Contract[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("promotions")
}

/// Programa de referidos: un cliente (referidor) recomienda y otro (referido)
/// se da de alta con su codigo. Al firmar el primer contrato del referido, la
/// referral pasa a `converted` y se genera una promocion de un solo uso para
/// el referidor (`reward_promotion_id`).
model Referral {
  id                 String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  referrerCustomerId String    @map("referrer_customer_id") @db.Uuid
  referredCustomerId String    @unique @map("referred_customer_id") @db.Uuid
  /// pending | converted | cancelled
  status             String    @default("pending")
  rewardPromotionId  String?   @map("reward_promotion_id") @db.Uuid
  convertedAt        DateTime? @map("converted_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  referrer        Customer   @relation("ReferralReferrer", fields: [referrerCustomerId], references: [id], onDelete: Cascade)
  referred        Customer   @relation("ReferralReferred", fields: [referredCustomerId], references: [id], onDelete: Cascade)
  rewardPromotion Promotion? @relation(fields: [rewardPromotionId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([referrerCustomerId])
  @@map("referrals")
}

/// Campaña segmentada por email. Segmenta clientes/leads por criterios
/// (`segment` jsonb) y al enviarla encola una `communications` por destinatario
/// vía el outbox (`source = campaign:<id>`).
model Campaign {
  id              String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  name            String
  /// email (único canal en v1)
  channel         String    @default("email")
  subject         String
  bodyText        String    @map("body_text")
  /// Criterios de segmentación (audiencia + filtros), ver shared.
  segment         Json      @default("{}")
  /// draft | sending | sent | cancelled
  status          String    @default("draft")
  audienceCount   Int       @default(0) @map("audience_count")
  sentCount       Int       @default(0) @map("sent_count")
  scheduledFor    DateTime? @map("scheduled_for") @db.Timestamptz(6)
  sentAt          DateTime? @map("sent_at") @db.Timestamptz(6)
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("campaigns")
}

/// Revenue (ECRI): tanda de subida de precio a clientes en cartera. Aplica un
/// aumento (% o fijo) a los contratos del `scope`, con preaviso por email y
/// aplicación programada en `effectiveDate` (cron).
model RentIncrease {
  id              String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  name            String
  /// Filtros del scope (antigüedad mínima, local, tipo), ver shared.
  scope           Json      @default("{}")
  /// percentage | fixed
  increaseType    String    @map("increase_type")
  increaseValue   Decimal   @map("increase_value") @db.Decimal(10, 2)
  effectiveDate   DateTime  @map("effective_date") @db.Date
  /// scheduled | applied | cancelled
  status          String    @default("scheduled")
  affectedCount   Int       @default(0) @map("affected_count")
  appliedCount    Int       @default(0) @map("applied_count")
  mrrDelta        Decimal   @default(0) @map("mrr_delta") @db.Decimal(12, 2)
  noticeSent      Boolean   @default(false) @map("notice_sent")
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  appliedAt       DateTime? @map("applied_at") @db.Timestamptz(6)

  tenant Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  RentIncreaseItem[]

  @@index([tenantId, status])
  @@index([status, effectiveDate])
  @@map("rent_increases")
}

/// Un contrato dentro de una tanda ECRI, con el precio antiguo/nuevo congelado.
model RentIncreaseItem {
  id             String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  rentIncreaseId String    @map("rent_increase_id") @db.Uuid
  contractId     String    @map("contract_id") @db.Uuid
  oldPrice       Decimal   @map("old_price") @db.Decimal(10, 2)
  newPrice       Decimal   @map("new_price") @db.Decimal(10, 2)
  /// pending | applied | skipped
  status         String    @default("pending")
  skipReason     String?   @map("skip_reason")
  appliedAt      DateTime? @map("applied_at") @db.Timestamptz(6)

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rentIncrease RentIncrease @relation(fields: [rentIncreaseId], references: [id], onDelete: Cascade)
  contract     Contract     @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([rentIncreaseId, contractId])
  @@index([tenantId])
  @@map("rent_increase_items")
}

/// Revenue: plan de seguro / protección de contenido (catálogo del tenant).
/// Se asigna a un contrato y se factura como línea recurrente del alquiler.
model InsurancePlan {
  id             String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  name           String
  monthlyPrice   Decimal  @map("monthly_price") @db.Decimal(10, 2)
