{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "StorageOS NestJS",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "declaration": true,
    "sourceMap": true,
    "removeComments": true
  }
}
