# =============================================================================
# .env.prod.example — Plantilla de entorno de PRODUCCION (StorageOS)
#
# USO:
#   1) En el VPS:  cp .env.prod.example .env.prod
#   2) Rellena cada <PLACEHOLDER>. Genera secretos con los comandos indicados.
#   3) chmod 600 .env.prod   (contiene secretos; nunca se commitea)
#
# Lo consumen: api, worker, migrate (docker-compose.prod.yml) y scripts/backup.sh.
# El compose SOBREESCRIBE defensivamente DATABASE_URL, DATABASE_ADMIN_URL,
# REDIS_HOST/PORT/PASSWORD, MINIO_ENDPOINT/PORT/USE_SSL y ENABLE_WORKERS_IN_API
# para apuntar a los hostnames internos de la red Docker. Aun asi las dejamos
# aqui (las usan el servicio `migrate`, los scripts de backup y clientes psql/mc
# manuales).
#
# Variables marcadas [OBLIGATORIO]: el API no arranca sin ellas (validacion Zod).
# Las demas tienen default razonable en env.schema.ts.
# =============================================================================

# ---------- Releases ----------
# Tag de git que estas desplegando. Etiqueta las imagenes storageos/{api,web,worker}.
RELEASE_TAG=main

# ---------- Dominios ----------
WEB_BASE_URL=https://app.tu-dominio.com
# [BUILD-ARG] Se embebe en el bundle del frontend en build-time. DEBE ser el
# dominio HTTPS publico, NO http://api.
NEXT_PUBLIC_API_URL=https://api.tu-dominio.com
# Lista separada por comas de origenes permitidos por CORS.
ALLOWED_ORIGINS=https://app.tu-dominio.com

# ---------- Postgres ----------
# Rol admin (bypass RLS): solo lo usan migrate, backups y flujos sin tenant.
POSTGRES_USER=storageos
POSTGRES_PASSWORD=<openssl rand -base64 24>
POSTGRES_DB=storageos
# Rol restringido (RLS activo): lo usa el dia a dia del API/worker.
POSTGRES_APP_USER=storageos_app
POSTGRES_APP_PASSWORD=<openssl rand -base64 24>
# [OBLIGATORIO] El compose las reconstruye con los hostnames internos, pero
# Zod las exige presentes y validas. Mantenlas coherentes con lo de arriba.
DATABASE_URL=postgresql://storageos_app:<POSTGRES_APP_PASSWORD>@postgres:5432/storageos?schema=public
DATABASE_ADMIN_URL=postgresql://storageos:<POSTGRES_PASSWORD>@postgres:5432/storageos?schema=public

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<openssl rand -base64 24>
REDIS_DB=0

# ---------- MinIO / S3 ----------
MINIO_ROOT_USER=storageos
MINIO_ROOT_PASSWORD=<openssl rand -base64 24>
# [OBLIGATORIO] El API firma URLs con estas. Sin keys dedicadas, coinciden
# con las root de arriba.
MINIO_ACCESS_KEY=storageos
MINIO_SECRET_KEY=<igual que MINIO_ROOT_PASSWORD>
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET_UPLOADS=storageos-uploads
MINIO_BUCKET_INVOICES=storageos-invoices
MINIO_BUCKET_PLANS=storageos-plans
MINIO_BUCKET_REPORTS=storageos-reports
# Base URL publica para servir objetos (si expones MinIO via NPM en files.*).
MINIO_PUBLIC_URL=https://files.tu-dominio.com
# Opcional: redirect de la consola de MinIO si la publicas via NPM.
MINIO_BROWSER_REDIRECT_URL=

# ---------- JWT (3 secretos INDEPENDIENTES) ----------
# [OBLIGATORIO] cada uno >= 32 chars.  openssl rand -base64 64 | tr -d '\n'
JWT_ACCESS_SECRET=<openssl rand -base64 64>
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
JWT_2FA_PENDING_SECRET=<openssl rand -base64 64>
JWT_2FA_PENDING_TTL_SECONDS=300

# ---------- Cifrado simetrico AES-256-GCM (TOTP, certs AEAT, tokens Stripe) ----------
# [OBLIGATORIO] base64 que represente EXACTAMENTE 32 bytes.  openssl rand -base64 32
MASTER_ENCRYPTION_KEY=<openssl rand -base64 32>

# ---------- Cookies ----------
COOKIE_DOMAIN=.tu-dominio.com
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# ---------- Workers (Sub-bloque 14A.1) ----------
# El compose ya fuerza 'false' en el servicio `api`; el worker la ignora (su
# main.ts la fuerza a 'true'). Si NO levantas el contenedor worker, ponla a
# 'true' aqui para que el API ejecute los crons (no recomendado en prod).
ENABLE_WORKERS_IN_API=false

# ---------- Stripe ----------
# Test: sk_test_/pk_test_ para validar el ciclo SEPA (DEPLOYMENT.md 12B).
# Live: sk_live_/pk_live_ cuando vayas a cobrar de verdad.
STRIPE_SECRET_KEY=sk_live_xxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxx
# Lo da Stripe al registrar el endpoint https://api.tu-dominio.com/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# ---------- Veri*Factu (AEAT) ----------
# stub = sin envio real (demo).  sandbox = preproduccion AEAT.  production = real.
AEAT_MODE=stub
# NIF del tenant emisor (debe coincidir con el del certificado FNMT subido).
AEAT_TENANT_TAX_ID=B12345678
# Identificacion del Sistema Informatico (StorageOS), comun a todos los tenants.
AEAT_SISTEMA_NIF=B00000000
AEAT_SISTEMA_NOMBRE=StorageOS
AEAT_SISTEMA_VERSION=1.0.0
AEAT_SISTEMA_INSTALACION=001
# Endpoints SOAP oficiales (ya vienen por default; sobreescribe solo si cambian).
AEAT_SANDBOX_ENDPOINT=https://prewww1.aeat.es/wlpl/TIKE-CONT/ws/SistemaFacturacion/SistemaFacturacionV1
AEAT_PRODUCTION_ENDPOINT=https://www1.agenciatributaria.gob.es/wlpl/TIKE-CONT/ws/SistemaFacturacion/SistemaFacturacionV1
AEAT_TIMEOUT_MS=30000

# ---------- Email (Resend en prod) ----------
EMAIL_PROVIDER=resend
EMAIL_FROM_NAME=StorageOS
# Usa el subdominio verificado en Resend (ver DEPLOYMENT.md 10.5).
EMAIL_FROM_ADDRESS=no-reply@send.tu-dominio.com
RESEND_API_KEY=re_xxxxxxxx

# ---------- Super admin (Fase 8/9) ----------
# [OBLIGATORIO-prod] >= 32 chars (tiene default de dev: CAMBIALO).
SUPER_ADMIN_JWT_SECRET=<openssl rand -base64 64>
SUPER_ADMIN_JWT_TTL_SECONDS=28800
SUPER_ADMIN_REFRESH_TTL_SECONDS=604800
IMPERSONATION_TTL_SECONDS=3600

# ---------- Alertas de seguridad (brute-force) ----------
SECURITY_BRUTE_FORCE_THRESHOLD=5
SECURITY_BRUTE_FORCE_WINDOW_MINUTES=15
# Si esta vacio, las alertas solo se loggean (no se envia email).
SECURITY_ALERT_EMAIL=seguridad@tu-dominio.com

# ---------- Webhooks salientes ----------
WEBHOOK_DELIVERIES_RETENTION_DAYS=30

# ---------- OpenAPI / Swagger ----------
# En prod, false. Ponlo a true SOLO temporalmente y protege /api/docs con auth en NPM.
OPENAPI_ENABLED=false

# ---------- Sentry (observabilidad de errores) ----------
# Vacio = no-op. Misma DSN para api y worker.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# ---------- WhatsApp (stub hasta WABA real) ----------
WHATSAPP_PROVIDER=stub
WHATSAPP_FROM_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=

# ---------- Control de accesos / cerraduras (stub hasta MQTT real) ----------
LOCK_PROVIDER=stub
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=storageos

# ---------- Logger ----------
LOG_LEVEL=info
# En prod, false (JSON estructurado para Loki/Grafana).
LOG_PRETTY=false

# ---------- Backups (scripts/backup.sh -> Backblaze B2) ----------
BACKUP_GPG_PASSPHRASE=<openssl rand -base64 24>
BACKUP_LOCAL_DIR=/opt/storageos/backups
BACKUP_RETENTION_DAYS=30
B2_BUCKET=storageos-backups
B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
B2_REGION=eu-central-003
B2_ACCESS_KEY_ID=<keyID de B2>
B2_SECRET_ACCESS_KEY=<applicationKey de B2>
