{
  "uid": "storageos-overview",
  "title": "TrasterOS — Overview",
  "tags": ["storageos"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Volumen de logs por servicio",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (service) (count_over_time({job=\"storageos\"}[$__interval]))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Errores API/worker (24h)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 25 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service=~\"api|worker\", level=~\"error|fatal\"}[$__interval]))"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Violaciones CSP (24h)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service=\"web\", evt=\"csp_violation\"}[$__interval]))"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Intentos de login fallidos",
      "datasource": { "type": "postgres", "uid": "postgres" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60 } } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "postgres" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(occurred_at, '1h'), event_type::text AS metric, count(*) AS value FROM security_events WHERE $__timeFilter(occurred_at) AND event_type::text LIKE 'login_failed%' GROUP BY 1, event_type ORDER BY 1"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Top emails/IP con login fallido",
      "datasource": { "type": "postgres", "uid": "postgres" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "postgres" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT email_attempted AS email, host(ip_address) AS ip, count(*) AS intentos, max(occurred_at) AS ultimo FROM security_events WHERE $__timeFilter(occurred_at) AND event_type::text LIKE 'login_failed%' GROUP BY email_attempted, ip_address ORDER BY intentos DESC LIMIT 20"
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Errores recientes (API/worker)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 16 },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=~\"api|worker\", level=~\"error|fatal\"}"
        }
      ]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Violaciones CSP recientes",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 16 },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"web\", evt=\"csp_violation\"}"
        }
      ]
    }
  ]
}
