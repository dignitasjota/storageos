# Variables de docker-compose para desarrollo.
# Copia este archivo a `.env` (no versionado) antes de levantar los servicios.
#
#   cp .env.example .env

# === Compose ===
COMPOSE_PROJECT_NAME=storageos

# === Postgres ===
POSTGRES_USER=storageos
POSTGRES_PASSWORD=storageos
POSTGRES_DB=storageos

# === MinIO ===
MINIO_ROOT_USER=storageos
MINIO_ROOT_PASSWORD=storageos-dev-only

# === Backup dentro del stack (perfil `backup`, opt-in) ===
# Activar con COMPOSE_PROFILES=backup. Respalda Postgres a diario a Backblaze B2.
BACKUP_GPG_PASSPHRASE=cambia-esta-frase-de-cifrado
B2_ENDPOINT=https://s3.us-west-000.backblazeb2.com
B2_BUCKET=storageos-backups
B2_REGION=us-west-000
B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=
BACKUP_RETENTION_DAYS=30
BACKUP_INTERVAL_SECONDS=86400
