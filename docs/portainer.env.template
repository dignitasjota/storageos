# ============================================================================
# PLANTILLA DE VARIABLES DE PORTAINER — TrasterOS (stack de producción)
# ============================================================================
#
# CÓMO USARLA:
#   1. En Portainer → Stacks → tu stack → sección "Environment variables"
#      (modo avanzado / "Advanced mode" = editor de texto KEY=value por línea).
#   2. Copia SOLO las líneas sin `#`, rellena los <VALORES> y pégalas.
#   3. Rellena por FASES (abajo). No hace falta rellenar todo de golpe:
#      las variables con "(opcional)" tienen un valor por defecto seguro en el
#      compose y pueden dejarse fuera hasta que las necesites.
#
# REGLAS DE ORO:
#   - NUNCA dejes una variable de email/URL con string VACÍO ("") — bórrala
#     entera. Zod la trata como "ausente"; un "" rompe la validación .email()/.url().
#   - Las contraseñas que van dentro de una URL de conexión (POSTGRES_*,
#     REDIS_PASSWORD) deben ser SOLO alfanuméricas (sin / + = @ : espacios), o
#     romperán la cadena de conexión. Genera con:  openssl rand -hex 24
#   - Postgres solo aplica su contraseña al CREAR el volumen. Si la cambias
#     luego, hay que recrear el volumen o hacer ALTER ROLE.
#
# GENERAR SECRETOS (ejecuta en cualquier terminal):
#   Secrets JWT (hex, URL-safe):     openssl rand -hex 48
#   MASTER_ENCRYPTION_KEY (base64):  openssl rand -base64 32
#   Passwords de servicio (hex):     openssl rand -hex 24
#
# ============================================================================


# ─── FASE 0 — DOMINIO Y URLs (imprescindible) ────────────────────────────────
# Sustituye <dominio> por tu dominio real en TODAS.
NEXT_PUBLIC_API_URL=https://api.<dominio>
NEXT_PUBLIC_SITE_URL=https://app.<dominio>
WEB_BASE_URL=https://app.<dominio>
ALLOWED_ORIGINS=https://app.<dominio>
# URL pública de MinIO (imágenes de locales de la landing). Si sirves MinIO
# tras NPM en s3.<dominio>, ponla; si no, deja la interna.
MINIO_PUBLIC_URL=https://s3.<dominio>


# ─── FASE 0 — POSTGRES / REDIS / MINIO (secretos de infraestructura) ─────────
# Passwords SOLO alfanuméricas (van en URLs). Genera cada una con `openssl rand -hex 24`.
POSTGRES_DB=storageos
POSTGRES_USER=storageos                 # rol admin (bypass RLS)
POSTGRES_PASSWORD=<hex-24>
POSTGRES_APP_USER=storageos_app         # rol restringido (RLS) que usa la app
POSTGRES_APP_PASSWORD=<hex-24>
REDIS_PASSWORD=<hex-24>
MINIO_ROOT_USER=storageos
MINIO_ROOT_PASSWORD=<hex-24>


# ─── FASE 0 — SECRETOS DE LA APP (imprescindible) ────────────────────────────
JWT_ACCESS_SECRET=<hex-48>              # openssl rand -hex 48
JWT_2FA_PENDING_SECRET=<hex-48>         # openssl rand -hex 48
SUPER_ADMIN_JWT_SECRET=<hex-48>         # openssl rand -hex 48
MASTER_ENCRYPTION_KEY=<base64-32>       # openssl rand -base64 32  (32 bytes)

# Cookies del refresh token (producción con HTTPS).
COOKIE_DOMAIN=<dominio>                 # p. ej. midominio.com (sin https://)
COOKIE_SECURE=true
COOKIE_SAMESITE=lax


# ─── FASE 1.2 — BOOTSTRAP DEL SUPER ADMIN ────────────────────────────────────
# Se usan una sola vez por el servicio one-shot `bootstrap`. Contraseña
# alfanumérica (la valida como parte de una URL interna).
BOOTSTRAP_SUPERADMIN_EMAIL=admin@<dominio>
BOOTSTRAP_SUPERADMIN_PASSWORD=<contraseña-alfanumérica-fuerte>
BOOTSTRAP_SUPERADMIN_NAME=Super Admin


# ─── FASE 1.3 — EMAIL (Resend) ───────────────────────────────────────────────
EMAIL_PROVIDER=resend
EMAIL_FROM_NAME=<NombreComercial>
EMAIL_FROM_ADDRESS=no-reply@send.<dominio>   # dominio verificado en Resend (SPF+DKIM)
RESEND_API_KEY=re_<...>
# Destinatario de alertas de seguridad (brute force). OPCIONAL pero recomendado.
# Debe ir en el bloque `api` del compose (ya viene comentada); si la defines,
# descomenta también la línea en docker-compose.portainer.yml → servicio api.
# SECURITY_ALERT_EMAIL=security@<dominio>


# ─── FASE 1.4 — STRIPE LIVE ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_<...>
STRIPE_PUBLISHABLE_KEY=pk_live_<...>
STRIPE_WEBHOOK_SECRET=whsec_<...>       # signing secret del webhook /webhooks/stripe


# ─── FASE 1.5 — VERI*FACTU / AEAT ────────────────────────────────────────────
# Empieza en sandbox para el dry-run; cuando valide, pon production y recrea el api.
AEAT_MODE=sandbox                        # sandbox → production
AEAT_SISTEMA_NIF=<NIF-del-sistema>       # NIF del titular del software (tú)
AEAT_SISTEMA_NOMBRE=TrasterOS
AEAT_SISTEMA_VERSION=1.0.0
AEAT_SISTEMA_INSTALACION=001
# AEAT_TENANT_TAX_ID solo si operas un único tenant; en multi-tenant se deja vacío
# (cada tenant sube su certificado FNMT en su panel /settings/billing/verifactu).


# ─── FASE 1.7 — MONITORIZACIÓN (Sentry) ──────────────────────────────────────
# OPCIONAL de formato estricto: si la defines, descomenta también la línea
# `SENTRY_DSN: ${SENTRY_DSN}` en el servicio api del docker-compose.portainer.yml.
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>


# ─── FASE 1.8 — BACKUPS (perfil `backup`, Backblaze B2) ──────────────────────
# Requeridas si activas COMPOSE_PROFILES=backup. Sin el perfil, se ignoran.
BACKUP_GPG_PASSPHRASE=<frase-de-cifrado-fuerte>
B2_ENDPOINT=https://s3.us-west-000.backblazeb2.com
B2_BUCKET=<nombre-bucket-b2>
B2_REGION=us-west-000
B2_ACCESS_KEY_ID=<keyID-de-b2>
B2_SECRET_ACCESS_KEY=<applicationKey-de-b2>
# BACKUP_RETENTION_DAYS=30
# BACKUP_INTERVAL_SECONDS=86400


# ─── VARIOS (con valor por defecto seguro; overridea solo si hace falta) ──────
LOG_LEVEL=info
# OPENAPI_ENABLED=false                  # /api/docs — solo tras auth/VPN
# LOCK_PROVIDER=stub                     # stub | mqtt | http (control de accesos físico)
# WHATSAPP_PROVIDER=stub                 # stub | meta_waba


# ============================================================================
# FASE 2 — OPCIONALES QUE NO ESTÁN AÚN EN EL COMPOSE (requieren EDITAR el YAML)
# ============================================================================
# Estas variables NO están en el anchor `x-app-env` del compose. Para activarlas
# hay que (a) añadir la línea `NOMBRE: ${NOMBRE}` al bloque environment del
# servicio api (y worker si aplica) en docker-compose.portainer.yml, y (b)
# definir el valor aquí en Portainer. Ver docs/ONBOARDING.md Fase 2.
#
#   # Redsys (TPV): URL pública del API para la notificación
#   API_BASE_URL=https://api.<dominio>
#
#   # Asistente IA (Claude real)                       [api + worker]
#   AI_PROVIDER=anthropic
#   ANTHROPIC_API_KEY=sk-ant-<...>
#   AI_MODEL=claude-sonnet-4-6
#
#   # Push (Web Push / PWA) — genera con `npx web-push generate-vapid-keys`  [api + worker]
#   VAPID_PUBLIC_KEY=<...>
#   VAPID_PRIVATE_KEY=<...>
#   VAPID_SUBJECT=mailto:admin@<dominio>
#
#   # WhatsApp Business real (saliente)                [api + worker]
#   WHATSAPP_PROVIDER=meta_waba
#   WHATSAPP_ACCESS_TOKEN=<...>
#   WHATSAPP_FROM_PHONE_ID=<...>
#
#   # Inbound de mensajes (respuestas del inquilino)   [api]
#   WHATSAPP_VERIFY_TOKEN=<...>
#   WHATSAPP_APP_SECRET=<...>
#   EMAIL_INBOUND_SECRET=<...>
#
#   # Secret dedicado del portal (opcional; por defecto usa JWT_2FA_PENDING_SECRET)
#   PORTAL_JWT_SECRET=<hex-48>


# ============================================================================
# FASE 2 — OBSERVABILIDAD Loki/Grafana (perfil `observability`)
# ============================================================================
# Solo si activas COMPOSE_PROFILES=observability. Requiere Proxy Host grafana.<dominio>.
# GF_ADMIN_USER=admin
# GF_ADMIN_PASSWORD=<contraseña-grafana>
# GF_SERVER_ROOT_URL=https://grafana.<dominio>
# GF_ALERT_EMAIL=alertas@<dominio>       # por defecto usa SECURITY_ALERT_EMAIL
# GF_SMTP_ENABLED=true
# GF_SMTP_HOST=smtp.<proveedor>:587
# GF_SMTP_USER=<...>
# GF_SMTP_PASSWORD=<...>
# GF_SMTP_FROM_ADDRESS=alertas@<dominio>


# ============================================================================
# PERFILES DE COMPOSE (activa servicios opcionales)
# ============================================================================
# El servicio `backup` y el stack `observability` son opt-in por perfil. Para
# activarlos, añade en Portainer:
#   COMPOSE_PROFILES=backup                    # solo backups
#   COMPOSE_PROFILES=backup,observability      # backups + Loki/Grafana
