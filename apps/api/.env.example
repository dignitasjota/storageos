NODE_ENV=development
PORT=3001

# Postgres (host:5433 -> contenedor:5432 del docker-compose).
# La API conecta como `storageos_app`, un rol restringido sometido a las
# politicas Row-Level Security. Para flujos sin contexto de tenant
# (register, resolver tenant por slug, audit logs) usa el rol admin
# `storageos`, expuesto en DATABASE_ADMIN_URL.
DATABASE_URL=postgresql://storageos_app:storageos-app@localhost:5433/storageos?schema=public
DATABASE_ADMIN_URL=postgresql://storageos:storageos@localhost:5433/storageos?schema=public

# Redis
REDIS_URL=redis://localhost:6380
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0

# === Stripe ===
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# === Verifactu ===
# stub = no envío real (Fase 4), sandbox/production en Fase 8.
AEAT_MODE=stub
AEAT_TENANT_TAX_ID=
# Endpoints SOAP de AEAT. Solo se usan si AEAT_MODE=sandbox o production.
AEAT_SANDBOX_ENDPOINT=https://prewww1.aeat.es/wlpl/TIKE-CONT/ws/SistemaFacturacion/SistemaFacturacionV1
AEAT_PRODUCTION_ENDPOINT=https://www1.agenciatributaria.gob.es/wlpl/TIKE-CONT/ws/SistemaFacturacion/SistemaFacturacionV1
AEAT_TIMEOUT_MS=30000

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9010
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=storageos
MINIO_SECRET_KEY=storageos-dev-only
MINIO_BUCKET_UPLOADS=storageos-uploads
MINIO_BUCKET_INVOICES=storageos-invoices
MINIO_BUCKET_PLANS=storageos-plans
MINIO_BUCKET_REPORTS=storageos-reports
# Bucket PUBLIC-READ (anonymous download) para imágenes de locales en la landing.
# NO meter aquí nada sensible. En prod: `mc anonymous set download <bucket>`.
MINIO_BUCKET_PUBLIC=storageos-public
MINIO_PUBLIC_URL=http://localhost:9010

# SMTP (Mailpit en dev). Usamos 127.0.0.1 (no `localhost`) porque Mailpit
# escucha solo en IPv4 y Node resolveria `localhost` a `::1` (IPv6).
SMTP_HOST=127.0.0.1
SMTP_PORT=1026
SMTP_FROM=no-reply@storageos.local
SMTP_FROM_NAME=StorageOS

# URL publica del frontend; se incrusta en los enlaces de los emails.
WEB_BASE_URL=http://localhost:3000

# === JWT ===
# En produccion: secret de al menos 64 chars aleatorios.
JWT_ACCESS_SECRET=dev-access-secret-change-me-in-production-cccccccccccccccccccccc
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
# Secret independiente para firmar el pendingToken del flujo 2FA (>= 32 chars).
JWT_2FA_PENDING_SECRET=dev-2fa-pending-secret-change-me-in-prodddddddddddd
JWT_2FA_PENDING_TTL_SECONDS=300

# === Cifrado simetrico de secrets en BD (AES-256-GCM) ===
# Clave maestra en base64; debe representar 32 bytes.
# Genera una nueva con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_ENCRYPTION_KEY=changeme-base64-32-bytes-aaaaaaaaaaaaaaaaaaaa=

# === Cookies del refresh token ===
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# === CORS ===
ALLOWED_ORIGINS=http://localhost:3000

# === Security alerts (Fase 12A.2) ===
# Numero de fallos consecutivos en la ventana SECURITY_BRUTE_FORCE_WINDOW_MINUTES
# que disparan una alerta por email al super admin.
SECURITY_BRUTE_FORCE_THRESHOLD=5
SECURITY_BRUTE_FORCE_WINDOW_MINUTES=15
# Destinatario de las alertas. Si no se define, las alertas quedan
# deshabilitadas (solo se hace logging).
# SECURITY_ALERT_EMAIL=security@storageos.local

# === OpenAPI / Swagger ===
# Activa la documentacion interactiva en GET /api/docs (y el JSON en
# /api/docs-json). En desarrollo y test se monta automaticamente; en
# produccion solo cuando esta variable sea true (y siempre debe quedar
# detras de auth en Nginx Proxy Manager / VPN).
OPENAPI_ENABLED=false

# === Workers en el API (Sub-bloque 14A.1) ===
# Si true (default), el API ejecuta Processors BullMQ y Crons in-process.
# En produccion con apps/worker separado, poner a false para evitar que
# los crons se disparen dos veces (API + worker) y se dupliquen facturas,
# emails y acciones de dunning.
ENABLE_WORKERS_IN_API=true

# === Sentry ===
# DSN del proyecto Sentry (https://sentry.io o autohospedado). Sin valor,
# Sentry es un no-op total: dev/test no necesitan cuenta. El API reporta
# los errores 5xx desde HttpExceptionFilter; el worker captura unhandled
# rejections/exceptions. Misma variable para api y worker.
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# Sample rate de tracing APM (0 = solo errores, sin transacciones).
# SENTRY_TRACES_SAMPLE_RATE=0

# === Logger ===
LOG_LEVEL=info
LOG_PRETTY=true
