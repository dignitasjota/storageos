NODE_ENV=development
PORT=3001

# Postgres (host:5433 -> contenedor:5432 del docker-compose)
DATABASE_URL=postgresql://storageos:storageos@localhost:5433/storageos?schema=public

# Redis
REDIS_URL=redis://localhost:6380

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9010
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=storageos
MINIO_SECRET_KEY=storageos-dev-only
MINIO_BUCKET_UPLOADS=storageos-uploads
MINIO_BUCKET_INVOICES=storageos-invoices
MINIO_BUCKET_PLANS=storageos-plans

# SMTP (Mailpit en dev)
SMTP_HOST=localhost
SMTP_PORT=1026
SMTP_FROM=no-reply@storageos.local

# JWT (placeholders; se rotarán en Fase 1)
JWT_ACCESS_SECRET=change-me-in-fase-1
JWT_REFRESH_SECRET=change-me-in-fase-1
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
