{
  "extends": "@storageos/tsconfig/nestjs.json",
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["node", "jest"],
    "outDir": "dist",
    "rootDir": "src",
    // Las plantillas de email se escriben como componentes React.
    "jsx": "react-jsx"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}
