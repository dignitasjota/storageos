{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false
  },
  "include": ["src/**/*", "../api/src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*.spec.ts",
    "../api/node_modules",
    "../api/dist",
    "../api/test",
    "../api/src/**/*.spec.ts",
    "../api/src/**/__tests__/**"
  ]
}
