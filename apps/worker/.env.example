# =============================================================================
# apps/worker/.env.example
#
# El worker comparte el mismo schema de entorno que la API (apps/api). Las
# variables que aparecen aqui son el SUBCONJUNTO estrictamente necesario
# para que `WorkerModule` arranque y procese las colas BullMQ + crons.
#
# En despliegue real (docker-compose.prod.yml) el worker reusa `.env.prod`
# del API para evitar duplicar configuracion.
#
# NOTA Sub-bloque 14A.1: el worker NO necesita la var
# `ENABLE_WORKERS_IN_API`. Su `main.ts` la fuerza a `'true'` antes de
# importar nada para garantizar que los modulos del API se carguen con
# los Processors y Crons activos, independientemente de lo que diga
# `.env.prod` (donde el API tiene `ENABLE_WORKERS_IN_API=false`).
# =============================================================================

NODE_ENV=production
LOG_LEVEL=info
LOG_PRETTY=false

# --- Postgres (mismo que API) ---
DATABASE_URL=postgresql://storageos_app:CHANGE_ME@postgres:5432/storageos?schema=public
DATABASE_ADMIN_URL=postgresql://storageos:CHANGE_ME@postgres:5432/storageos?schema=public

# --- Redis (BullMQ) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_DB=0

# --- JWT (algunos servicios reusados firman tokens) ---
JWT_ACCESS_SECRET=CHANGE_ME_AT_LEAST_32_CHARACTERS_LONG
JWT_2FA_PENDING_SECRET=CHANGE_ME_AT_LEAST_32_CHARACTERS_LONG

# --- Cifrado simetrico de secrets en BD ---
MASTER_ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTES

# --- MinIO / S3 (PDFs de facturas, reports, contratos) ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_PUBLIC_URL=https://files.tu-dominio.com

# --- Stripe (para webhooks / sync que aun toque el worker) ---
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- AEAT Verifactu ---
AEAT_MODE=stub
AEAT_TENANT_TAX_ID=
AEAT_SISTEMA_NIF=B00000000

# --- Email provider ---
EMAIL_PROVIDER=resend
EMAIL_FROM_NAME=StorageOS
EMAIL_FROM_ADDRESS=no-reply@tu-dominio.com
RESEND_API_KEY=re_xxx

# --- Lock provider (control de accesos fisico) ---
LOCK_PROVIDER=stub
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=storageos

# --- Web base url (links en emails) ---
WEB_BASE_URL=https://app.tu-dominio.com

# --- Super admin (algunos crons de seguridad notifican aqui) ---
SUPER_ADMIN_JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARACTERS_LONG
SECURITY_ALERT_EMAIL=alerts@tu-dominio.com
