{
  "extends": "@storageos/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "plugins": [{ "name": "next" }],
    // Componentes Radix/shadcn no respetan exactOptionalPropertyTypes: tipan
    // props como `T` que aceptan undefined en runtime. Relajamos para web;
    // el resto del monorepo lo mantiene activo.
    "exactOptionalPropertyTypes": false
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next", "dist"]
}
